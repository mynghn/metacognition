#!/usr/bin/env python3
"""skill-activation-check-selftest — behavioral tests for the activation scorer.

Each test pins a property the scorer must preserve (run after any change); it drives the REAL tool via
subprocess over a fixture corpus + fixture transcripts + a fixture manifest + fixture baselines built in
a tmpdir:
  - the worklist flags a should_fire=true scenario that missed on a trial as [miss <skill> k/N], and a
    should_fire=false scenario that fired on a trial as [false-fire <skill> k/N]; a scenario correct on
    every trial produces NO line;
  - the rates are the mean fire-fraction over the should_fire=true scenarios (self-use) and over the
    should_fire=false scenarios (false-fire), aggregated across trials rather than read from one run;
  - the gate promotes iff self-use clears baseline + margin AND false-fire stays within the bar, and
    holds otherwise (lift failure and precision failure each tested);
  - --record-baseline writes the {self_use_rate, false_fire_rate, margin, false_fire_bar, n_trials,
    recorded_at} artifact;
  - a malformed corpus, and a transcript whose schema the reader rejects, each fail clean (rc 2, no
    traceback) rather than scoring wrong;
  - an all-correct run writes nothing to stdout.
"""
import json
import os
import shutil
import subprocess
import sys
import tempfile

TOOL = os.path.join(os.path.dirname(os.path.abspath(__file__)), "skill-activation-check")

_checks = []


def check(name, ok, detail=""):
    _checks.append(bool(ok))
    print("  %s %s%s" % ("PASS" if ok else "FAIL", name, ("  — " + str(detail)) if detail and not ok else ""))


def write_jsonl(path, records):
    with open(path, "w", encoding="utf-8") as fh:
        for r in records:
            fh.write(r if isinstance(r, str) else json.dumps(r))
            fh.write("\n")


def run(args):
    return subprocess.run([sys.executable, TOOL, *args], capture_output=True, text=True)


# transcript fixtures: a compact-focus firing, a handoff firing, a silent run, and a broken-schema run
CF_FIRE = [{"type": "user", "message": {"role": "user", "content": "go"}},
           {"type": "assistant", "message": {"role": "assistant", "content": [
               {"type": "tool_use", "name": "Skill", "input": {"skill": "compact-focus"}}]}}]
HO_FIRE = [{"type": "assistant", "attributionSkill": "handoff",
            "message": {"role": "assistant", "content": [{"type": "text", "text": "handing off"}]}}]
SILENT = [{"type": "user", "message": {"role": "user", "content": "do x"}},
          {"type": "assistant", "message": {"role": "assistant", "content": [
              {"type": "tool_use", "name": "Bash", "input": {"command": "ls"}}]}}]


def main():
    root = tempfile.mkdtemp(prefix="sac-selftest-")
    try:
        tx = os.path.join(root, "tx")
        os.makedirs(tx)
        cf1, cf2 = os.path.join(tx, "cf1.jsonl"), os.path.join(tx, "cf2.jsonl")
        ho1 = os.path.join(tx, "ho1.jsonl")
        s1, s2, s3, s4 = (os.path.join(tx, n) for n in ("s1.jsonl", "s2.jsonl", "s3.jsonl", "s4.jsonl"))
        for f in (cf1, cf2):
            write_jsonl(f, CF_FIRE)
        write_jsonl(ho1, HO_FIRE)
        for f in (s1, s2, s3, s4):
            write_jsonl(f, SILENT)

        corpus = os.path.join(root, "corpus.jsonl")
        write_jsonl(corpus, [
            {"id": "t1", "skill": "compact-focus", "setup": "x", "framing": "deliberation", "should_fire": True},
            {"id": "t2", "skill": "compact-focus", "setup": "x", "framing": "imperative", "should_fire": True},
            {"id": "t3", "skill": "handoff", "setup": "x", "framing": "imperative", "should_fire": False},
            {"id": "t4", "skill": "handoff", "setup": "x", "framing": "deliberation", "should_fire": True},
            {"id": "t5", "skill": "compact-focus", "setup": "x", "framing": "unrelated", "should_fire": False},
        ])
        # N=2 trials each: t1 fires 2/2, t2 1/2 (miss), t3 1/2 (false-fire), t4 0/2 (miss), t5 0/2 (correct)
        manifest = os.path.join(root, "runs.jsonl")
        write_jsonl(manifest, [
            {"id": "t1", "trial": 1, "transcript": cf1}, {"id": "t1", "trial": 2, "transcript": cf2},
            {"id": "t2", "trial": 1, "transcript": cf1}, {"id": "t2", "trial": 2, "transcript": s1},
            {"id": "t3", "trial": 1, "transcript": ho1}, {"id": "t3", "trial": 2, "transcript": s2},
            {"id": "t4", "trial": 1, "transcript": s3}, {"id": "t4", "trial": 2, "transcript": s4},
            {"id": "t5", "trial": 1, "transcript": s1}, {"id": "t5", "trial": 2, "transcript": s2},
        ])

        r = run(["--corpus", corpus, "--runs", manifest])
        check("scorer exits 0", r.returncode == 0, r.stderr)
        out = r.stdout
        check("miss flagged with k/N", "t2: [miss compact-focus] fired 1/2" in out, out)
        check("false-fire flagged with k/N", "t3: [false-fire handoff] fired 1/2" in out, out)
        check("full miss (0/N) flagged", "t4: [miss handoff] fired 0/2" in out, out)
        check("correct should_fire=true scenario not flagged", "t1:" not in out, out)
        check("correct should_fire=false scenario not flagged", "t5:" not in out, out)
        # rates: self-use mean(1.0, 0.5, 0.0)=0.50 ; false-fire mean(0.5, 0.0)=0.25
        check("self-use and false-fire rates computed", "self-use 0.50, false-fire 0.25" in r.stderr, r.stderr)

        # (c) gate — promote when lift clears margin and precision within bar
        promote_base = os.path.join(root, "base_promote.json")
        with open(promote_base, "w") as fh:
            json.dump({"self_use_rate": 0.40, "false_fire_rate": 0.30, "margin": 0.05,
                       "false_fire_bar": 0.30, "n_trials": 2, "recorded_at": "x"}, fh)
        rp = run(["--corpus", corpus, "--runs", manifest, "--baseline", promote_base])
        check("gate PROMOTE when self-use>=baseline+margin and false-fire<=bar",
              "verdict: PROMOTE" in rp.stderr, rp.stderr)

        # hold on lift failure
        hold_lift = os.path.join(root, "base_hold_lift.json")
        with open(hold_lift, "w") as fh:
            json.dump({"self_use_rate": 0.50, "margin": 0.05, "false_fire_bar": 0.30}, fh)
        rhl = run(["--corpus", corpus, "--runs", manifest, "--baseline", hold_lift])
        check("gate HOLD on lift failure (self-use below baseline+margin)",
              "verdict: HOLD" in rhl.stderr and "self-use" in rhl.stderr, rhl.stderr)

        # hold on precision failure
        hold_prec = os.path.join(root, "base_hold_prec.json")
        with open(hold_prec, "w") as fh:
            json.dump({"self_use_rate": 0.40, "margin": 0.05, "false_fire_bar": 0.20}, fh)
        rhp = run(["--corpus", corpus, "--runs", manifest, "--baseline", hold_prec])
        check("gate HOLD on precision failure (false-fire above bar)",
              "verdict: HOLD" in rhp.stderr and "false-fire" in rhp.stderr, rhp.stderr)

        # (d) --record-baseline artifact shape
        out_base = os.path.join(root, "recorded.json")
        rr = run(["--corpus", corpus, "--runs", manifest, "--record-baseline", out_base,
                  "--margin", "0.05", "--bar", "0.30", "--recorded-at", "2026-06-22T00:00:00"])
        check("--record-baseline exits 0", rr.returncode == 0, rr.stderr)
        artifact = json.load(open(out_base))
        check("baseline artifact has exactly the six fields",
              set(artifact) == {"self_use_rate", "false_fire_rate", "margin", "false_fire_bar", "n_trials", "recorded_at"},
              set(artifact))
        check("baseline records the computed rates + params + n_trials + recorded_at",
              artifact["self_use_rate"] == 0.5 and artifact["false_fire_rate"] == 0.25
              and artifact["margin"] == 0.05 and artifact["false_fire_bar"] == 0.30
              and artifact["n_trials"] == 2 and artifact["recorded_at"] == "2026-06-22T00:00:00", artifact)

        # (e) malformed corpus -> clean rc 2
        bad_corpus = os.path.join(root, "bad_corpus.jsonl")
        write_jsonl(bad_corpus, ['{"id": "x", "skill": "compact-focus"}'])  # missing schema keys
        rb = run(["--corpus", bad_corpus, "--runs", manifest])
        check("malformed corpus: clean error (rc 2, no traceback)",
              rb.returncode == 2 and "Traceback" not in rb.stderr, rb.stderr)

        # (e') transcript the reader rejects -> clean rc 2 (fail loud, not score wrong)
        broken_tx = os.path.join(tx, "broken.jsonl")
        write_jsonl(broken_tx, ['{"no": "type-key"}'])  # record lacks the {type,...} envelope
        bad_runs = os.path.join(root, "bad_runs.jsonl")
        write_jsonl(bad_runs, [{"id": "t1", "trial": 1, "transcript": broken_tx}])
        small_corpus = os.path.join(root, "small.jsonl")
        write_jsonl(small_corpus, [{"id": "t1", "skill": "compact-focus", "setup": "x",
                                    "framing": "deliberation", "should_fire": True}])
        rt = run(["--corpus", small_corpus, "--runs", bad_runs])
        check("unrecognized transcript schema: clean error (rc 2, no traceback)",
              rt.returncode == 2 and "Traceback" not in rt.stderr, rt.stderr)

        # (f) all-correct run -> silent stdout
        ac_corpus = os.path.join(root, "ac.jsonl")
        write_jsonl(ac_corpus, [
            {"id": "a1", "skill": "compact-focus", "setup": "x", "framing": "deliberation", "should_fire": True},
            {"id": "a2", "skill": "compact-focus", "setup": "x", "framing": "unrelated", "should_fire": False},
        ])
        ac_runs = os.path.join(root, "ac_runs.jsonl")
        write_jsonl(ac_runs, [
            {"id": "a1", "trial": 1, "transcript": cf1}, {"id": "a1", "trial": 2, "transcript": cf2},
            {"id": "a2", "trial": 1, "transcript": s1}, {"id": "a2", "trial": 2, "transcript": s2},
        ])
        rac = run(["--corpus", ac_corpus, "--runs", ac_runs])
        check("all-correct run writes nothing to stdout", rac.returncode == 0 and rac.stdout == "",
              repr(rac.stdout))
    finally:
        shutil.rmtree(root, ignore_errors=True)

    passed = sum(1 for ok in _checks if ok)
    total = len(_checks)
    print("\n%s: %d/%d checks passed" % ("PASS" if passed == total else "FAIL", passed, total))
    return 0 if passed == total else 1


if __name__ == "__main__":
    raise SystemExit(main())

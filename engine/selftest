#!/usr/bin/env python3
"""selftest — behavioral tests for kb-engine.

Each test encodes a behavior the engine must preserve, so this file is the durable home
for the engine's WHYs (run it after any engine change):

Parity (vs the legacy `*-kb` scripts):
  - valid capture writes the entry + a slug-sorted INDEX line (keeping section boilerplate);
  - INDEX stays slug-sorted across out-of-order captures;
  - capture refuses an existing slug; refresh refuses an absent one; refresh overwrites;
  - every frontmatter rule rejects AND writes nothing (atomicity);
  - the source-authority gate rejects a write whose sole support is below the SOURCES.md
    allowlist (>=1 allowlisted source admits), fails loud on a missing policy, and the policy
    module parses hosts / matches *. patterns / flags an uncorroborated load-bearing number;
  - a missing INDEX heading rejects with no orphan entry; invalid slug rejects;
  - CRLF input is accepted and normalized (legacy file-round-trip parity);
  - remove drops the entry file and its INDEX line.

Mutation (-> the vault repo):
  - every capture / refresh / remove records EXACTLY ONE commit in the vault repo;
  - provenance trailers round-trip out of `git log` while the subject stays the bare
    `<stem>: <verb> <slug>` form; a no-provenance write is byte-identical to today's commit;
    malformed `--trailer` is rejected before any write;
  - a rejected op records NO commit and leaves the tree unchanged;
  - the vault location resolves from $<PREFIX>_KB_VAULT / $KB_VAULT / default when --vault is omitted;
  - a non-git vault is refused.
"""
import os
import shutil
import subprocess
import sys
import tempfile

ENGINE = os.path.join(os.path.dirname(os.path.abspath(__file__)), "kb-engine")
DEFAULT_VAULT = os.path.expanduser("~/.local/share/metacognition-vault")

VALID_ENTRY = """---
name: {slug}
description: one-line retrieval trigger for {slug}
last_refreshed: 2026-06-20
sources:
  - Author, "Title", 2026 — https://example.com
---

A distilled, self-contained explanation of {slug}.

Related: [[something-else]]
"""

INDEX_SKELETON = """# Test KB — Index

Read this index first, then load only matching entries.

## Concepts

<!-- one line per concept; appended by capture/refresh -->
"""

# A permissive source policy for the parity/mutation tests, injected via $KB_SOURCES so every
# existing capture/refresh clears the write-gate on VALID_ENTRY's example.com source. The gate's
# own reject/admit behavior is exercised separately with explicit, restrictive --sources policies.
SOURCES_PERMISSIVE = (
    "# test policy\n"
    "```hosts\n"
    "example.com\n"
    "arxiv.org\n"
    "*.anthropic.com\n"
    "```\n"
)

_checks = []


def check(name, ok, detail=""):
    _checks.append((name, ok, detail))
    print("  %s %s%s" % ("PASS" if ok else "FAIL", name, ("  — " + detail) if detail and not ok else ""))


def git(vault, *args):
    return subprocess.run(["git", "-C", vault, *args], capture_output=True, text=True)


def ncommits(vault):
    return int(git(vault, "rev-list", "--count", "HEAD").stdout or "0")


def make_vault(heading="## Concepts", init_git=True):
    vault = tempfile.mkdtemp(prefix="kb-selftest-")
    tdir = os.path.join(vault, "test-topic")
    os.makedirs(os.path.join(tdir, "knowledge"))
    with open(os.path.join(tdir, "INDEX.md"), "w", encoding="utf-8") as fh:
        fh.write(INDEX_SKELETON.replace("## Concepts", heading))
    cfg = os.path.join(vault, "config")
    with open(cfg, "w", encoding="utf-8") as fh:
        fh.write("stem = test-topic\nindex_heading = Concepts\nenv_prefix = CE\ntier = everyday\n")
    if init_git:
        git(vault, "init", "-q")
        git(vault, "config", "user.name", "selftest")
        git(vault, "config", "user.email", "selftest@example.com")
        git(vault, "add", "-A")
        git(vault, "commit", "-q", "-m", "init")
    return vault, tdir, cfg


def run(cfg, vault, args, stdin=None, env=None):
    cmd = [sys.executable, ENGINE, "--config", cfg]
    if vault is not None:
        cmd += ["--vault", vault]
    return subprocess.run(cmd + args, input=stdin, capture_output=True, text=True, env=env)


def index_lines(tdir):
    with open(os.path.join(tdir, "INDEX.md"), encoding="utf-8") as fh:
        return fh.read().split("\n")


def entry_slugs(tdir):
    return [l.split("[", 1)[1].split("]", 1)[0] for l in index_lines(tdir) if l.startswith("- [")]


def main():
    pol_dir = tempfile.mkdtemp(prefix="kb-sources-")
    permissive = os.path.join(pol_dir, "SOURCES.md")
    with open(permissive, "w", encoding="utf-8") as fh:
        fh.write(SOURCES_PERMISSIVE)
    os.environ["KB_SOURCES"] = permissive
    vault, tdir, cfg = make_vault()
    try:
        base = ncommits(vault)

        # valid capture: writes entry + INDEX line, keeps boilerplate, ONE commit
        r = run(cfg, vault, ["capture", "beta"], VALID_ENTRY.format(slug="beta"))
        check("capture exits 0", r.returncode == 0, r.stderr)
        check("capture writes entry file", os.path.isfile(os.path.join(tdir, "knowledge", "beta.md")))
        check("capture inserts INDEX line", "beta" in entry_slugs(tdir))
        check("INDEX keeps boilerplate comment", any("one line per concept" in l for l in index_lines(tdir)))
        check("capture records exactly one commit", ncommits(vault) == base + 1, str(ncommits(vault) - base))
        check("commit message names topic + op", git(vault, "log", "-1", "--format=%s").stdout.strip()
              == "test-topic: capture beta")

        # out-of-order captures stay slug-sorted; each is one commit
        run(cfg, vault, ["capture", "alpha"], VALID_ENTRY.format(slug="alpha"))
        run(cfg, vault, ["capture", "gamma"], VALID_ENTRY.format(slug="gamma"))
        check("INDEX slug-sorted", entry_slugs(tdir) == ["alpha", "beta", "gamma"], str(entry_slugs(tdir)))
        check("three captures -> three commits", ncommits(vault) == base + 3, str(ncommits(vault) - base))

        # capture refuses an existing slug: no change, NO commit
        n = ncommits(vault)
        before = open(os.path.join(tdir, "INDEX.md"), encoding="utf-8").read()
        r = run(cfg, vault, ["capture", "beta"], VALID_ENTRY.format(slug="beta"))
        check("capture refuses existing slug", r.returncode != 0, r.stderr)
        check("refused capture: INDEX unchanged",
              open(os.path.join(tdir, "INDEX.md"), encoding="utf-8").read() == before)
        check("refused capture: no commit", ncommits(vault) == n)

        # refresh refuses absent; overwrites existing (one commit)
        r = run(cfg, vault, ["refresh", "nope"], VALID_ENTRY.format(slug="nope"))
        check("refresh refuses absent slug", r.returncode != 0, r.stderr)
        n = ncommits(vault)
        r = run(cfg, vault, ["refresh", "beta"],
                VALID_ENTRY.format(slug="beta").replace("one-line retrieval trigger for beta", "REFRESHED trigger"))
        check("refresh exits 0", r.returncode == 0, r.stderr)
        check("refresh updates INDEX description", any("REFRESHED trigger" in l for l in index_lines(tdir)))
        check("refresh records one commit", ncommits(vault) == n + 1)

        # every frontmatter rule rejects AND writes nothing AND makes no commit (atomicity)
        n = ncommits(vault)
        bad = {
            "no-frontmatter": "no frontmatter here\n",
            "name-mismatch": VALID_ENTRY.format(slug="different-name").replace("name: different-name", "name: wrong"),
            "empty-description": VALID_ENTRY.format(slug="bad-desc").replace(
                "description: one-line retrieval trigger for bad-desc", "description:"),
            "missing-last-refreshed": "\n".join(
                l for l in VALID_ENTRY.format(slug="no-date").split("\n") if not l.startswith("last_refreshed:")) + "\n",
            "missing-sources": "\n".join(
                l for l in VALID_ENTRY.format(slug="no-src").split("\n")
                if not l.startswith("sources:") and not l.strip().startswith("- Author")) + "\n",
        }
        for slug, body in bad.items():
            r = run(cfg, vault, ["capture", slug], body)
            wrote = os.path.isfile(os.path.join(tdir, "knowledge", slug + ".md"))
            check("reject bad frontmatter: %s" % slug, r.returncode != 0 and not wrote,
                  "rc=%s wrote=%s" % (r.returncode, wrote))
        check("rejected captures made no commits", ncommits(vault) == n)

        # invalid slug rejects
        r = run(cfg, vault, ["capture", "Bad_Slug"], VALID_ENTRY.format(slug="Bad_Slug"))
        check("reject invalid slug", r.returncode != 0)

        # CRLF input accepted + normalized to LF (legacy round-trip parity)
        r = run(cfg, vault, ["capture", "crlf-entry"], VALID_ENTRY.format(slug="crlf-entry").replace("\n", "\r\n"))
        check("CRLF entry accepted", r.returncode == 0, r.stderr)
        crlf_path = os.path.join(tdir, "knowledge", "crlf-entry.md")
        check("CRLF entry normalized to LF",
              os.path.isfile(crlf_path) and "\r" not in open(crlf_path, encoding="utf-8", newline="").read())

        # remove drops entry file + INDEX line, one commit
        n = ncommits(vault)
        r = run(cfg, vault, ["remove", "beta"])
        check("remove exits 0", r.returncode == 0, r.stderr)
        check("remove drops entry file", not os.path.exists(os.path.join(tdir, "knowledge", "beta.md")))
        check("remove drops INDEX line", "beta" not in entry_slugs(tdir))
        check("remove records one commit", ncommits(vault) == n + 1)
        r = run(cfg, vault, ["remove", "ghost"])
        check("remove refuses absent slug", r.returncode != 0)

        # provenance trailers: an automated heal/evolution commit is self-describing — its
        # structured trailers round-trip out of `git log`, while the subject stays the bare
        # `<stem>: <verb> <slug>` form (provenance lives in git history, not in the subject).
        n = ncommits(vault)
        r = run(cfg, vault, ["capture", "healed",
                             "--trailer", "Heal-verdict:stale",
                             "--trailer", "Heal-mode:auto",
                             "--trailer", "Heal-confidence:0.9",
                             "--trailer", "Sources-before:https://old.example.com",
                             "--trailer", "Sources-after:https://arxiv.org/abs/1, https://arxiv.org/abs/2",
                             "--trailer", "Heal-run:run-42"],
                VALID_ENTRY.format(slug="healed"))
        check("capture with provenance exits 0", r.returncode == 0, r.stderr)
        check("provenance records exactly one commit", ncommits(vault) == n + 1)

        def trailer(key):
            return git(vault, "log", "-1", "--format=%%(trailers:key=%s,valueonly)" % key).stdout.strip()
        check("provenance: Heal-verdict recoverable from git log", trailer("Heal-verdict") == "stale", trailer("Heal-verdict"))
        check("provenance: Heal-mode recoverable", trailer("Heal-mode") == "auto", trailer("Heal-mode"))
        check("provenance: Heal-confidence recoverable", trailer("Heal-confidence") == "0.9", trailer("Heal-confidence"))
        check("provenance: Sources-after preserves comma-joined urls",
              trailer("Sources-after") == "https://arxiv.org/abs/1, https://arxiv.org/abs/2", trailer("Sources-after"))
        check("provenance: subject stays the bare stem/verb/slug form",
              git(vault, "log", "-1", "--format=%s").stdout.strip() == "test-topic: capture healed")

        # a remove (= retire) carries provenance through the same path
        run(cfg, vault, ["remove", "healed", "--trailer", "Heal-verdict:retire", "--trailer", "Heal-mode:ratified"])
        check("retire (remove) carries provenance", trailer("Heal-verdict") == "retire", trailer("Heal-verdict"))

        # back-compat: a no-provenance write is BYTE-IDENTICAL to today's commit message
        # (bare subject, empty body — no trailers paragraph), so adding provenance support never
        # silently rewrites the existing human-CLI commit shape.
        run(cfg, vault, ["capture", "plain"], VALID_ENTRY.format(slug="plain"))
        check("no-provenance: subject unchanged",
              git(vault, "log", "-1", "--format=%s").stdout.strip() == "test-topic: capture plain")
        check("no-provenance: empty body (no trailers paragraph appended)",
              git(vault, "log", "-1", "--format=%b").stdout.strip() == "")
        check("no-provenance: git parses zero trailers",
              git(vault, "log", "-1", "--format=%(trailers)").stdout.strip() == "")

        # malformed provenance is rejected before any write — a bad --trailer must fail loudly,
        # never silently degrade into non-trailer commit-body text.
        n = ncommits(vault)
        r = run(cfg, vault, ["capture", "badtrail", "--trailer", "no-colon-here"], VALID_ENTRY.format(slug="badtrail"))
        check("malformed --trailer (no colon) rejected", r.returncode != 0 and "KEY:VALUE" in r.stderr, r.stderr)
        r = run(cfg, vault, ["capture", "badkey", "--trailer", "Bad Key:value"], VALID_ENTRY.format(slug="badkey"))
        check("--trailer with non-token key rejected", r.returncode != 0 and "trailer token" in r.stderr, r.stderr)
        check("rejected provenance wrote no entry + no commit",
              not os.path.isfile(os.path.join(tdir, "knowledge", "badtrail.md")) and ncommits(vault) == n)

        # source-authority gate: a write whose sole support is below the allowlist is rejected
        # (never written dirty); >=1 allowlisted source admits. Authority (host vs allowlist) is
        # the engine's deterministic half — citation resolve/support is the skill's envelope.
        strict = os.path.join(pol_dir, "strict.md")
        with open(strict, "w", encoding="utf-8") as fh:
            fh.write("# strict\n```hosts\narxiv.org\n*.anthropic.com\n```\n")
        n = ncommits(vault)
        weak = VALID_ENTRY.format(slug="weak").replace("https://example.com", "https://random-blog.example.net")
        r = run(cfg, vault, ["capture", "weak", "--sources", strict], weak)
        check("sub-allowlist sole source rejected", r.returncode != 0 and "source authority" in r.stderr, r.stderr)
        check("gate-rejected write: no entry, no commit",
              not os.path.isfile(os.path.join(tdir, "knowledge", "weak.md")) and ncommits(vault) == n)
        strong = VALID_ENTRY.format(slug="strong").replace("https://example.com", "https://arxiv.org/abs/2401.00001")
        r = run(cfg, vault, ["capture", "strong", "--sources", strict], strong)
        check("allowlisted source admitted", r.returncode == 0, r.stderr)
        mixed = VALID_ENTRY.format(slug="mixed").replace(
            "https://example.com\n",
            "https://random-blog.example.net\n  - Paper — https://arxiv.org/abs/2401.00002\n")
        r = run(cfg, vault, ["capture", "mixed", "--sources", strict], mixed)
        check("mixed sources admitted when >=1 clears the bar", r.returncode == 0, r.stderr)

        # a missing / empty policy fails LOUD — the writer never silently skips the authority bar
        r = run(cfg, vault, ["capture", "nopol", "--sources", os.path.join(pol_dir, "absent.md")],
                VALID_ENTRY.format(slug="nopol"))
        check("missing source policy fails loud (no silent skip)",
              r.returncode != 0 and "source policy not found" in r.stderr, r.stderr)

        # SOURCES.md policy module (unit): the parser the write-gate AND the health-check
        # source-lint both consume — one parser, so their bars can never drift.
        sys.path.insert(0, os.path.dirname(ENGINE))
        import sources as S
        pats, found = S.load_allowlist(strict)
        check("hosts block parses", found and "arxiv.org" in pats and "*.anthropic.com" in pats, str(pats))
        check("apex host matches bare pattern", S.host_allowed("arxiv.org", pats))
        check("subdomain matches *. pattern", S.host_allowed("docs.anthropic.com", pats))
        check("apex matches *. pattern", S.host_allowed("anthropic.com", pats))
        check("non-allowlisted host rejected", not S.host_allowed("evil.example.net", pats))
        check("absent policy reports found=False (caller fails loud, not empty-allows)",
              S.load_allowlist(os.path.join(pol_dir, "absent.md"))[1] is False)
        num_body = ("---\nname: x\ndescription: d\nlast_refreshed: 2026-01-01\n"
                    "sources:\n  - One — https://arxiv.org/abs/1\n---\n\n"
                    "A benchmark of 194,480 calls hit 90% accuracy in 2025.\n")
        check("corroboration flags a load-bearing number on a single source",
              "194,480" in S.corroboration_flag(num_body), str(S.corroboration_flag(num_body)))
        two_src = num_body.replace("sources:\n  - One — https://arxiv.org/abs/1\n",
                                   "sources:\n  - One — https://arxiv.org/abs/1\n  - Two — https://www.anthropic.com/x\n")
        check("corroboration clears with a 2nd distinct source", S.corroboration_flag(two_src) == [])
        check("a bare year is not a load-bearing number", "2025" not in S.load_bearing_numbers(num_body))

        # locate resolves paths (incl. the vault)
        r = run(cfg, vault, ["locate", "alpha"])
        check("locate exits 0", r.returncode == 0, r.stderr)
        check("locate prints vault + entry", vault in r.stdout and "alpha.md" in r.stdout)

        # vault-location resolution when --vault is omitted
        clean = {k: v for k, v in os.environ.items() if k not in ("KB_VAULT", "CE_KB_VAULT")}
        r = run(cfg, None, ["locate"], env=dict(clean, KB_VAULT=vault))
        check("resolves $KB_VAULT", r.returncode == 0 and vault in r.stdout, r.stderr + r.stdout)
        r = run(cfg, None, ["locate"], env=dict(clean, CE_KB_VAULT=vault))
        check("resolves $<PREFIX>_KB_VAULT", r.returncode == 0 and vault in r.stdout, r.stderr + r.stdout)
        r = run(cfg, None, ["locate"], env=clean)
        check("falls back to default vault", DEFAULT_VAULT in r.stdout, r.stdout)

        # the op's commit is scoped: an unrelated already-staged vault change is NOT swept in
        with open(os.path.join(vault, "unrelated.txt"), "w", encoding="utf-8") as fh:
            fh.write("staged but unrelated\n")
        git(vault, "add", "unrelated.txt")
        run(cfg, vault, ["capture", "scoped"], VALID_ENTRY.format(slug="scoped"))
        committed = git(vault, "show", "--name-only", "--format=", "HEAD").stdout.split()
        check("commit excludes unrelated staged file", "unrelated.txt" not in committed, str(committed))
        check("unrelated file still staged (uncommitted)",
              "unrelated.txt" in git(vault, "diff", "--cached", "--name-only").stdout)

        # a non-git vault is refused (mutation needs a repo to record into)
        v2, t2, c2 = make_vault(init_git=False)
        try:
            r = run(c2, v2, ["capture", "x"], VALID_ENTRY.format(slug="x"))
            check("non-git vault refused", r.returncode != 0 and "git repo" in r.stderr, r.stderr)
        finally:
            shutil.rmtree(v2, ignore_errors=True)

        # nested-vault guard: a vault dir NESTED inside an outer repo must be refused — never
        # commit the change into the enclosing (e.g. dotfiles) repo.
        outer = tempfile.mkdtemp(prefix="kb-outer-")
        try:
            for a in (["init", "-q"], ["config", "user.name", "o"], ["config", "user.email", "o@e"]):
                git(outer, *a)
            open(os.path.join(outer, "seed.txt"), "w").write("x")
            git(outer, "add", "-A")
            git(outer, "commit", "-q", "-m", "seed")
            nested = os.path.join(outer, "subvault")
            os.makedirs(os.path.join(nested, "test-topic", "knowledge"))
            with open(os.path.join(nested, "test-topic", "INDEX.md"), "w") as fh:
                fh.write(INDEX_SKELETON)
            ncfg = os.path.join(outer, "cfg")
            with open(ncfg, "w") as fh:
                fh.write("stem = test-topic\nindex_heading = Concepts\n")
            n_outer = ncommits(outer)
            r = run(ncfg, nested, ["capture", "leak"], VALID_ENTRY.format(slug="leak"))
            check("nested-non-repo vault refused", r.returncode != 0 and "repo root" in r.stderr, r.stderr)
            check("outer repo got NO commit (no leak into the enclosing repo)", ncommits(outer) == n_outer)
            check("nested capture wrote no entry",
                  not os.path.isfile(os.path.join(nested, "test-topic", "knowledge", "leak.md")))
        finally:
            shutil.rmtree(outer, ignore_errors=True)

        # commit failure (a failing pre-commit hook) rolls back atomically: clean error,
        # no orphan entry, no commit, clean index, INDEX restored
        v4, t4, c4 = make_vault()
        try:
            hook = os.path.join(v4, ".git", "hooks", "pre-commit")
            with open(hook, "w") as fh:
                fh.write("#!/bin/sh\nexit 1\n")
            os.chmod(hook, 0o755)
            n4 = ncommits(v4)
            r = run(c4, v4, ["capture", "hookfail"], VALID_ENTRY.format(slug="hookfail"))
            check("commit failure: clean error (no traceback)",
                  r.returncode != 0 and "Traceback" not in r.stderr and "rolled back" in r.stderr, r.stderr)
            check("commit failure: no orphan entry", not os.path.isfile(os.path.join(t4, "knowledge", "hookfail.md")))
            check("commit failure: no commit", ncommits(v4) == n4)
            check("commit failure: clean index", git(v4, "diff", "--cached", "--name-only").stdout.strip() == "")
            check("commit failure: INDEX restored",
                  "hookfail" not in open(os.path.join(t4, "INDEX.md"), encoding="utf-8").read())
        finally:
            shutil.rmtree(v4, ignore_errors=True)

        # absent git binary -> clean error, no orphan
        v5, t5, c5 = make_vault()
        try:
            r = run(c5, v5, ["capture", "nogit"], VALID_ENTRY.format(slug="nogit"),
                    env=dict(os.environ, PATH="/nonexistent"))
            check("git absent: clean error (no traceback)",
                  r.returncode != 0 and "git not found" in r.stderr and "Traceback" not in r.stderr, r.stderr)
            check("git absent: no orphan entry", not os.path.isfile(os.path.join(t5, "knowledge", "nogit.md")))
        finally:
            shutil.rmtree(v5, ignore_errors=True)

        # config stem with traversal is rejected at load, before any write (defense-in-depth)
        v6, t6, _ = make_vault()
        try:
            badcfg = os.path.join(v6, "badcfg")
            with open(badcfg, "w") as fh:
                fh.write("stem = ../escape\nindex_heading = Concepts\n")
            r = run(badcfg, v6, ["capture", "x"], VALID_ENTRY.format(slug="x"))
            check("traversal stem rejected", r.returncode != 0 and "single path component" in r.stderr, r.stderr)
            check("traversal wrote nothing outside vault",
                  not os.path.exists(os.path.join(os.path.dirname(v6), "escape")))
        finally:
            shutil.rmtree(v6, ignore_errors=True)

        # env-var whitespace: whitespace-only falls through to default; space-wrapped resolves trimmed
        clean2 = {k: v for k, v in os.environ.items() if k not in ("KB_VAULT", "CE_KB_VAULT")}
        r = run(cfg, None, ["locate"], env=dict(clean2, KB_VAULT="   "))
        check("whitespace-only $KB_VAULT falls through to default", DEFAULT_VAULT in r.stdout, r.stdout)
        r = run(cfg, None, ["locate"], env=dict(clean2, KB_VAULT="  " + vault + "  "))
        check("space-wrapped $KB_VAULT resolves trimmed", vault in r.stdout, r.stdout)

        # absent vault: the error names the vault, not the INDEX
        r = run(cfg, "/nonexistent/vault/path", ["capture", "x"], VALID_ENTRY.format(slug="x"))
        check("absent vault: error names the vault", r.returncode != 0 and "vault not found" in r.stderr, r.stderr)

        # missing INDEX heading rejects WITH NO orphan entry (atomicity fix)
        v3, t3, c3 = make_vault(heading="## Other")
        try:
            r = run(c3, v3, ["capture", "orphan"], VALID_ENTRY.format(slug="orphan"))
            wrote = os.path.isfile(os.path.join(t3, "knowledge", "orphan.md"))
            check("missing heading rejects with no orphan", r.returncode != 0 and not wrote,
                  "rc=%s wrote=%s" % (r.returncode, wrote))
        finally:
            shutil.rmtree(v3, ignore_errors=True)
    finally:
        shutil.rmtree(vault, ignore_errors=True)
        shutil.rmtree(pol_dir, ignore_errors=True)

    passed = sum(1 for _, ok, _ in _checks if ok)
    total = len(_checks)
    print("\n%s: %d/%d checks passed" % ("PASS" if passed == total else "FAIL", passed, total))
    return 0 if passed == total else 1


if __name__ == "__main__":
    raise SystemExit(main())

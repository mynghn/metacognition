#!/usr/bin/env python3
"""kb-engine — the shared operations engine for the Metacognition family.

ONE engine backs every sibling's capture / refresh / remove / locate, parameterized
by a thin per-sibling config. Re-derived from the three near-duplicate `*-kb` scripts
(which were byte-identical but for per-sibling tokens), so the family's operations live
in a single source and an operation change takes effect family-wide with no per-sibling
copy to edit.

It validates + writes the entry + upserts the slug-sorted INDEX (and removes / locates)
against a vault folder, then records each change as exactly one commit in the vault repo's
own history, resolving the vault location from env / installer config / a standard default.
There is NO chezmoi path — the legacy source-write -> `chezmoi apply` -> commit-into-dotfiles
is gone; every mutation is one validated channel straight to the vault repo, so a knowledge
change records to the vault's own history and never to personal config. Validation, write,
and commit all live here, so nothing bypasses them.

Operation semantics are preserved exactly from the `*-kb` scripts:
  - frontmatter: `name` == slug, non-empty `description`, `last_refreshed` present, `sources` present
  - INDEX upsert sorted by slug under the configured `## <index_heading>` section
  - capture refuses an existing slug; refresh refuses an absent one
  - kebab-case slug only
  - one commit per change (now to the vault repo, not the dotfiles repo)

A per-sibling config is a flat `key = value` file (see templates/sibling-config.schema.md).
The engine consumes `stem` (the vault topic folder), `index_heading`, and `env_prefix`
(vault-location override); `tier` is reserved for the installer's discovery wiring.
"""
import argparse
import os
import re
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import sources  # engine-local module: the SOURCES.md authority-policy logic (shared with health-check)

PROG = "kb-engine"


def die(msg):
    sys.stderr.write("%s: %s\n" % (PROG, msg))
    raise SystemExit(1)


def load_config(path):
    """Parse a flat `key = value` config (shell- and python-readable; `#` comments)."""
    if not os.path.isfile(path):
        die("config not found: %s" % path)
    cfg = {}
    with open(path, encoding="utf-8") as fh:
        for raw in fh:
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if "=" not in line:
                die("config: malformed line (expected `key = value`): %r" % line)
            k, v = line.split("=", 1)
            cfg[k.strip()] = v.strip()
    for required in ("stem", "index_heading"):
        if not cfg.get(required):
            die("config missing required field %r (%s)" % (required, path))
    stem = cfg["stem"]
    if stem in (".", "..") or stem != os.path.basename(stem):
        die("config: 'stem' must be a single path component (no '/', '..', or absolute), got %r" % stem)
    return cfg


def valid_slug(slug):
    if not re.match(r"^[a-z0-9][a-z0-9-]*$", slug):
        die("invalid slug %r (kebab-case: a-z 0-9 -)" % slug)


def topic_dir(vault, cfg):
    return os.path.join(vault, cfg["stem"])


DEFAULT_VAULT = "~/.local/share/metacognition-vault"


def resolve_vault(explicit, cfg):
    """Resolve the vault repo location, in precedence order:
    explicit `--vault`; a per-sibling `<PREFIX>_KB_VAULT` env override; the family-level
    `KB_VAULT` env; the installer-recorded config file; then a standard default. The vault
    is ONE repo holding every topic, so `KB_VAULT` is the family override and
    `<PREFIX>_KB_VAULT` is the per-sibling hook (the escape hatch for a sibling that ever needs its own vault). The config file is written by the installer; its path is the engine<->installer contract.
    """
    chosen = _clean_path(explicit)
    if chosen:
        return chosen
    prefix = cfg.get("env_prefix")
    if prefix:
        chosen = _clean_path(os.environ.get(prefix + "_KB_VAULT"))
        if chosen:
            return chosen
    chosen = _clean_path(os.environ.get("KB_VAULT"))
    if chosen:
        return chosen
    conf = os.path.join(
        os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config"),
        "metacognition", "vault",
    )
    if os.path.isfile(conf):
        chosen = _clean_path(open(conf, encoding="utf-8").read())
        if chosen:
            return chosen
    return _clean_path(DEFAULT_VAULT)


def _clean_path(value):
    """Normalize a vault-location source: strip, expanduser, and absolutize (cwd-independent).
    Blank/whitespace-only -> None so resolution falls through to the next source uniformly."""
    if not value or not value.strip():
        return None
    return os.path.abspath(os.path.expanduser(value.strip()))


def _require_git_repo(vault):
    """The vault must be a git repo ROOT — mutation records to its OWN history. Checked
    before any write so a missing / non-repo / nested-inside-another-repo vault fails before
    the working tree is touched. The root check is load-bearing: a vault dir nested inside an
    outer repo (e.g. an uninitialized vault under a git-tracked $HOME) must NOT let a change
    commit into that outer/dotfiles repo — the exact leak this home is built to prevent."""
    if not os.path.isdir(vault):
        die("vault not found: %s (run the installer, or pass --vault)" % vault)
    try:
        top = subprocess.run(
            ["git", "-C", vault, "rev-parse", "--show-toplevel"], capture_output=True, text=True,
        )
    except FileNotFoundError:
        die("git not found on PATH — install git or fix PATH")
    if top.returncode != 0:
        die("vault is not a git repo: %s (run the installer to set up the vault)" % vault)
    root = top.stdout.strip()
    if os.path.realpath(root) != os.path.realpath(vault):
        die("vault %s is not a git repo root — it sits inside %s; run the installer to init "
            "the vault (refusing to commit into the enclosing repo)" % (vault, root))


def _rollback(vault, rels):
    """After a failed commit, restore the op-paths to HEAD: unstage, then restore each from
    HEAD (an existing entry / the INDEX) or delete it (a brand-new capture not yet in HEAD),
    so a failed mutation leaves no orphan entry or stale INDEX line behind."""
    subprocess.run(["git", "-C", vault, "reset", "-q", "--"] + rels, capture_output=True)
    for rel in rels:
        in_head = subprocess.run(
            ["git", "-C", vault, "cat-file", "-e", "HEAD:" + rel], capture_output=True,
        ).returncode == 0
        if in_head:
            subprocess.run(["git", "-C", vault, "checkout", "HEAD", "--", rel], capture_output=True)
        else:
            try:
                os.remove(os.path.join(vault, rel))
            except OSError:
                pass


def parse_trailers(raw):
    """Parse repeated `--trailer KEY:VALUE` strings into ordered (key, value) git-trailer
    pairs (or None when unset). Split on the FIRST colon so a URL value keeps its own colons
    (`Sources-after:https://…`). KEY must be a git-trailer token; a malformed key or a
    multi-line value is rejected here, before any write — a bad provenance arg must fail loudly,
    never silently degrade into ordinary commit-body text that `git log` won't parse back."""
    if not raw:
        return None
    out = []
    for item in raw:
        if ":" not in item:
            die("--trailer must be KEY:VALUE, got %r" % item)
        k, v = item.split(":", 1)
        k, v = k.strip(), v.strip()
        if not re.match(r"^[A-Za-z][A-Za-z0-9-]*$", k):
            die("--trailer key %r is not a valid git-trailer token (letters, digits, '-')" % k)
        if "\n" in v:
            die("--trailer value for %r must be single-line" % k)
        out.append((k, v))
    return out


def commit_change(vault, cfg, slug, verb, provenance=None):
    """Stage the entry + INDEX and record exactly one commit in the vault repo's history,
    scoped to those two paths. The mutation and its commit are one engine step — a single
    controlled channel: on any git failure the working tree is rolled back to HEAD, so a half-written change can
    never persist, and git errors surface as a clean message rather than a Python traceback.

    `provenance` — an ordered list of (key, value) git-trailer pairs, or None — appends
    structured trailers after the subject (`git commit -m <subject> -m <trailers>`) so an
    automated heal/evolution commit is self-describing and auditable straight from `git log`.
    Change history lives in git, not frontmatter (which holds current state, not why a change
    happened). None reproduces the bare `<stem>: <verb> <slug>` subject byte-for-byte, so a
    human CLI write is unchanged. The engine stays generic about WHICH trailers it records —
    the heal vocabulary (Heal-verdict, Heal-mode, Sources-before/after, …) is the caller's
    schema, not the engine's, so the shared writer never learns one feature's words."""
    rels = [
        os.path.join(cfg["stem"], "knowledge", slug + ".md"),
        os.path.join(cfg["stem"], "INDEX.md"),
    ]
    commit_cmd = ["git", "-C", vault, "commit", "-q", "-m", "%s: %s %s" % (cfg["stem"], verb, slug)]
    if provenance:
        commit_cmd += ["-m", "\n".join("%s: %s" % (k, v) for k, v in provenance)]
    commit_cmd += ["--"] + rels
    try:
        subprocess.run(["git", "-C", vault, "add", "--"] + rels, check=True, capture_output=True, text=True)
        # Scope the change-check AND the commit to exactly these two paths (`-- rels`), so the
        # op's commit can never sweep in an unrelated already-staged change in the vault.
        if subprocess.run(["git", "-C", vault, "diff", "--cached", "--quiet", "--"] + rels).returncode == 0:
            die("nothing changed for %r — no commit made" % slug)
        subprocess.run(commit_cmd, check=True, capture_output=True, text=True)
    except FileNotFoundError:
        die("git not found on PATH — install git or fix PATH")
    except subprocess.CalledProcessError as exc:
        _rollback(vault, rels)
        die("git failed (change rolled back): %s" % ((exc.stderr or "").strip() or exc))
    return subprocess.run(
        ["git", "-C", vault, "rev-parse", "--short", "HEAD"], capture_output=True, text=True,
    ).stdout.strip()


def _frontmatter_fields(body):
    """Return a field-lookup over the entry's YAML frontmatter, or die if absent."""
    m = re.match(r"^---\n(.*?)\n---\n", body, re.S)
    if not m:
        die("entry has no YAML frontmatter")
    fm = m.group(1)

    def field(name):
        mm = re.search(r"(?m)^%s:[ \t]*(.+?)[ \t]*$" % name, fm)
        return mm.group(1).strip() if mm else None

    return fm, field


def _validate_frontmatter(body, slug):
    """Validate frontmatter and return the description. Pure check — writes nothing."""
    fm, field = _frontmatter_fields(body)
    if field("name") != slug:
        die("frontmatter name %r != slug %r" % (field("name"), slug))
    desc = field("description")
    if not desc:
        die("frontmatter 'description' missing/empty")
    if not field("last_refreshed"):
        die("frontmatter 'last_refreshed' missing")
    if not re.search(r"(?m)^sources:", fm):
        die("frontmatter 'sources' missing")
    return desc


def _index_path(tdir):
    idx = os.path.join(tdir, "INDEX.md")
    if not os.path.isfile(idx):
        die("INDEX.md not found under %s" % tdir)
    return idx


def _index_heading_pos(lines, cfg):
    heading = "## " + cfg["index_heading"]
    for i, line in enumerate(lines):
        if line.strip() == heading:
            return i
    die("INDEX.md missing %r section" % heading)


def _upsert_index(idx, lines, h, slug, desc):
    """Upsert the entry's INDEX line, keeping the section slug-sorted (ported verbatim
    from the `*-kb` python block)."""
    line = "- [%s](knowledge/%s.md) — %s" % (slug, slug, desc.strip("\"'"))
    entry_re = re.compile(r"^- \[([a-z0-9-]+)\]\(knowledge/\1\.md\) — ")
    # Keep pre-entry lines (section comment/blanks); collect entry lines for re-sorting.
    # NOTE: any non-entry line AFTER the first entry is intentionally dropped — exact parity
    # with the legacy `*-kb` upsert (the section is heading + boilerplate + entry list, no tail).
    keep, ents, seen = [], {}, False
    for line_after in lines[h + 1:]:
        mm = entry_re.match(line_after)
        if mm:
            ents[mm.group(1)] = line_after
            seen = True
        elif not seen:
            keep.append(line_after)
    ents[slug] = line
    while keep and keep[-1].strip() == "":
        keep.pop()
    out = lines[: h + 1] + keep + [""] + [ents[k] for k in sorted(ents)] + [""]
    with open(idx, "w", encoding="utf-8") as fh:
        fh.write("\n".join(out))


def write_entry(verb, vault, cfg, slug, provenance=None, sources_path=None):
    valid_slug(slug)
    _require_git_repo(vault)
    tdir = topic_dir(vault, cfg)
    entry = os.path.join(tdir, "knowledge", slug + ".md")
    if verb == "capture":
        if os.path.exists(entry):
            die("entry %r exists — use 'refresh %s' to supersede it" % (slug, slug))
    else:
        if not os.path.exists(entry):
            die("entry %r not found — use 'capture %s' to create it" % (slug, slug))
    if sys.stdin.isatty():
        die("no entry markdown on stdin — pipe the full <slug>.md content")
    # Normalize newlines (CRLF/CR -> LF) to match the legacy `*-kb` round-trip, which read the
    # body via a temp file under universal-newline translation; without this a CRLF entry would
    # fail the `^---\n` frontmatter match that the legacy accepted (parity regression).
    body = sys.stdin.read().replace("\r\n", "\n").replace("\r", "\n")

    # Validate EVERYTHING (frontmatter + INDEX section) before any write, so a rejected
    # op never leaves an orphan entry or half-written INDEX. The `*-kb`
    # scripts wrote the entry before checking the heading; pre-validating closes that gap
    # with no change on valid input.
    desc = _validate_frontmatter(body, slug)
    # Source-authority gate (part of the pre-write validation, so a rejected write is never
    # written dirty): a missing policy fails LOUD — the writer never silently skips the bar —
    # and an entry whose sole support is below the allowlist is refused, leaving any existing
    # entry untouched. Citation RESOLVE + SUPPORT (network + judgment) is the skill's envelope,
    # not this deterministic host check.
    patterns, found = sources.load_allowlist(sources_path)
    if not found:
        die("source policy not found or empty: %s — cannot enforce source authority "
            "(pass --sources or restore SOURCES.md)" % sources_path)
    violation = sources.authority_violation(body, patterns)
    if violation:
        die("source authority: %s" % violation)
    idx = _index_path(tdir)
    lines = open(idx, encoding="utf-8").read().split("\n")
    h = _index_heading_pos(lines, cfg)

    os.makedirs(os.path.join(tdir, "knowledge"), exist_ok=True)
    with open(entry, "w", encoding="utf-8") as fh:
        fh.write(body)
    _upsert_index(idx, lines, h, slug, desc)
    sha = commit_change(vault, cfg, slug, verb, provenance)
    past = verb + ("d" if verb.endswith("e") else "ed")  # capture->captured, refresh->refreshed
    sys.stdout.write("%s: %s %s (%s)\n" % (PROG, past, slug, sha))


def remove_entry(vault, cfg, slug, provenance=None):
    valid_slug(slug)
    _require_git_repo(vault)
    tdir = topic_dir(vault, cfg)
    entry = os.path.join(tdir, "knowledge", slug + ".md")
    if not os.path.exists(entry):
        die("entry %r not found" % slug)
    idx = _index_path(tdir)
    pat = re.compile(r"^- \[%s\]\(knowledge/%s\.md\) — " % (re.escape(slug), re.escape(slug)))
    lines = open(idx, encoding="utf-8").read().split("\n")
    os.remove(entry)
    with open(idx, "w", encoding="utf-8") as fh:
        fh.write("\n".join(l for l in lines if not pat.match(l)))
    sha = commit_change(vault, cfg, slug, "remove", provenance)
    sys.stdout.write("%s: removed %s (%s)\n" % (PROG, slug, sha))


def locate(vault, cfg, slug):
    tdir = topic_dir(vault, cfg)
    sys.stdout.write("vault: %s\n" % vault)
    sys.stdout.write("topic: %s\n" % tdir)
    sys.stdout.write("index: %s\n" % os.path.join(tdir, "INDEX.md"))
    if slug:
        valid_slug(slug)
        sys.stdout.write("entry: %s\n" % os.path.join(tdir, "knowledge", slug + ".md"))


def main(argv=None):
    p = argparse.ArgumentParser(prog=PROG, description="Shared KB operations engine.")
    p.add_argument("--config", required=True, help="per-sibling config file (key = value)")
    p.add_argument("--vault", help="vault repo root (default: resolved by precedence — "
                                   "$<PREFIX>_KB_VAULT / $KB_VAULT / installer config / %s)" % DEFAULT_VAULT)
    sub = p.add_subparsers(dest="op", required=True)
    trailer_help = ("structured git-trailer provenance (repeatable), e.g. "
                    "--trailer Heal-mode:auto — appended to the commit for audit")
    sources_help = "source-authority policy file (default: SOURCES.md at the engine repo root)"
    for op in ("capture", "refresh"):
        s = sub.add_parser(op, help="%s an entry (markdown on stdin)" % op)
        s.add_argument("slug")
        s.add_argument("--trailer", action="append", metavar="KEY:VALUE", help=trailer_help)
        s.add_argument("--sources", metavar="FILE", help=sources_help)
    s = sub.add_parser("remove", help="remove an entry")
    s.add_argument("slug")
    s.add_argument("--trailer", action="append", metavar="KEY:VALUE", help=trailer_help)
    s = sub.add_parser("locate", help="print the resolved topic/index/entry paths")
    s.add_argument("slug", nargs="?")
    args = p.parse_args(argv)

    cfg = load_config(args.config)
    vault = resolve_vault(args.vault, cfg)
    if args.op in ("capture", "refresh"):
        write_entry(args.op, vault, cfg, args.slug, parse_trailers(args.trailer),
                    sources.resolve_sources(args.sources))
    elif args.op == "remove":
        remove_entry(vault, cfg, args.slug, parse_trailers(args.trailer))
    elif args.op == "locate":
        locate(vault, cfg, args.slug)


if __name__ == "__main__":
    main()

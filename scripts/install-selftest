#!/usr/bin/env python3
"""install-selftest — robustness + idempotency tests for the installer.

Encodes the adversarial findings so they cannot regress: byte-identical Claude/Codex adapters,
idempotent re-run, stray/dotfiles in config/ skipped (not mis-treated as siblings), and CLEAN
errors (no Python tracebacks) for an unknown --only / a config missing a required field / a
sibling with no discovery description.

Tier-gated AGENTS.md trigger blocks: an Everyday-tier sibling gets its named block emitted
byte-exact into the shared AGENTS.md; a Situational sibling gets none; the upsert is SURGICAL
(replaces only its own <tag>...</tag> span, preserves every other block) and idempotent; and a
tier=everyday sibling missing its block file is a clean error.

Vault setup: the installer git-inits the vault as a repo ROOT, records its location at
$XDG_CONFIG_HOME/metacognition/vault, and the engine then resolves that vault with no
--vault/env. Every install here runs in a sandboxed vault + $XDG_CONFIG_HOME so the real ~/.config
and the live vault are never touched.

Maintenance skill (W6): a full install deploys the family-level metacognition-maintenance skill
(SKILL.md + references/) byte-identical to both providers with its @-tokens baked absolute, ships no
extra (scheduler/trigger) artifact so nothing runs unattended, is idempotent, deploys via `--only metacognition-maintenance`
yet is left untouched by a surgical `--only <sibling>`, and a file with an unbakeable @TOKEN@ is a clean error.

Practice-skill lane: a full install deploys the authored practice skills (handoff, compact-focus). The lane is
SHARED-by-default (one <name>/SKILL.md byte-identical to both providers) and PER-VENDOR by exception
(<name>/<provider>/SKILL.md when a runtime primitive forces the bodies apart), @VAULT@ baked either way, plus a shared
provider-neutral activation block upserted into AGENTS.md. Covered here: a shared SKILL.md reaches both providers
byte-identical; per-vendor bodies reach their own runtime; a shared + per-provider layout together is a clean error;
set-keyed discovery picks up a new skills/practice/<x>/ dir with no code change; the activation upsert is surgical +
idempotent; `--only <practice>` deploys just it; a surgical `--only <sibling>` leaves them alone; and an unbakeable
@TOKEN@ is a clean error.

Vendor-divergence gate: each per-vendor skill ships a golden `vendor-divergence` snapshot (content-not-position — the
sorted set of provider-unique lines). The gate asserts the live divergence equals the snapshot, so gratuitous drift or
a reconcile-toward-shared both fail until the snapshot is intentionally regenerated (`./scripts/install-selftest
--update-divergence`); a semantic check forbids any Claude-only primitive ($ARGUMENTS, `/compact <focus>`) in a Codex body.

Local hook setup: the main installer exposes the selftest gate's pre-commit hook as opt-in setup UX. Non-interactive
installs skip it by default; `--install-pre-commit` installs it; and an existing unmanaged hook is preserved and chained.
"""
import os
import re
import shutil
import subprocess
import sys
import tempfile

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.dirname(SCRIPT_DIR)
INSTALL = os.path.join(SCRIPT_DIR, "install")
CONFIG = os.path.join(ROOT, "config")
ENGINE = os.path.join(ROOT, "engine", "kb-engine")
PRACTICE_SRC = os.path.join(ROOT, "skills", "practice")
NAMES = ["context-engineering-knowledge-base", "prompt-engineering-knowledge-base", "tool-design-knowledge-base"]
RUNTIME_DIRS = (".claude", ".agents")
_ok = []
_VAULT = None  # sandbox vault, set in main(); injected into every install run so the real vault is untouched


def check(name, cond, detail=""):
    _ok.append(bool(cond))
    print("  %s %s%s" % ("PASS" if cond else "FAIL", name, ("  — " + detail) if detail and not cond else ""))


def run(args):
    if _VAULT and "--vault" not in args:
        args = ["--vault", _VAULT] + args
    return subprocess.run([sys.executable, INSTALL] + args, capture_output=True, text=True)


def read(dest, provider, name):
    return open(os.path.join(dest, provider, "skills", name, "SKILL.md"), encoding="utf-8").read()


def copy_install_repo(dest):
    """Copy the installable repo to a disposable git repo, excluding VCS/runtime noise, so explicit
    hook-install checks never touch this checkout's real .git/hooks."""
    def ignore(_dir, names):
        return {n for n in names if n in (".git", ".worktrees", "__pycache__") or n.endswith(".pyc")}
    shutil.copytree(ROOT, dest, ignore=ignore)
    subprocess.run(["git", "-C", dest, "init", "-q"], check=True)
    subprocess.run(["git", "-C", dest, "config", "user.email", "selftest@example.com"], check=True)
    subprocess.run(["git", "-C", dest, "config", "user.name", "selftest"], check=True)
    return os.path.join(dest, "scripts", "install")


# ---- vendor-divergence gate ---------------------------------------------------------------------
# A per-vendor practice skill (a claude/ AND a codex/ body) earns its split only when a runtime
# primitive forces the bodies apart. The gate freezes the SANCTIONED divergence as a golden snapshot
# so unjustified drift — gratuitous wording differences, or a Claude-only primitive leaking into the
# Codex body — fails the selftest. "Content-not-position" so a pure reorder of a shared line never
# trips it; only the SET of provider-unique lines matters. See skills/practice/README.md.

def _divergent_lines(text):
    """Non-blank, stripped lines — the unit the gate compares (CONTENT, not whitespace or position)."""
    return [ln.strip() for ln in text.splitlines() if ln.strip()]


def per_vendor_skills():
    """Practice skills shipped PER-VENDOR (a claude/ AND a codex/ SKILL.md) — the ones the gate
    governs. A shared-body skill (one <name>/SKILL.md) has no divergence and is skipped."""
    if not os.path.isdir(PRACTICE_SRC):
        return []
    out = []
    for f in sorted(os.listdir(PRACTICE_SRC)):
        d = os.path.join(PRACTICE_SRC, f)
        if f.startswith(".") or not os.path.isdir(d):
            continue
        if os.path.isfile(os.path.join(d, "claude", "SKILL.md")) and os.path.isfile(os.path.join(d, "codex", "SKILL.md")):
            out.append(f)
    return out


def render_divergence(name, only_claude, only_codex):
    """Serialize a per-vendor skill's content-not-position divergence to golden-snapshot text: the
    sorted sets of lines unique to each provider, under a self-documenting (re)generation header."""
    lines = [
        "# vendor-divergence snapshot — %s" % name,
        "# Content-not-position: non-blank lines unique to each provider's SKILL.md, sorted.",
        "# install-selftest asserts the LIVE divergence equals this snapshot; a diff here is the gate",
        "# firing — reconcile the bodies toward shared, or, if the new divergence is genuinely",
        "# runtime-forced, re-snapshot intentionally:  ./scripts/install-selftest --update-divergence",
        "",
        "## only in claude/ (%d)" % len(only_claude),
    ]
    lines += only_claude
    lines += ["", "## only in codex/ (%d)" % len(only_codex)]
    lines += only_codex
    return "\n".join(lines) + "\n"


def practice_divergence(name):
    """The LIVE content-not-position divergence between a per-vendor skill's two provider SKILL.md files,
    rendered as golden-snapshot text. Position-insensitive (reordering a shared line is invisible)
    but content-sensitive (any new/removed provider-unique line registers)."""
    d = os.path.join(PRACTICE_SRC, name)
    cset = set(_divergent_lines(open(os.path.join(d, "claude", "SKILL.md"), encoding="utf-8").read()))
    xset = set(_divergent_lines(open(os.path.join(d, "codex", "SKILL.md"), encoding="utf-8").read()))
    return render_divergence(name, sorted(cset - xset), sorted(xset - cset))


def divergence_snapshot_path(name):
    return os.path.join(PRACTICE_SRC, name, "vendor-divergence")


def update_divergence_snapshots():
    """Regenerate every per-vendor skill's golden divergence snapshot from current sources — the
    deliberate, documented way to move the gate after an intentional divergence change."""
    names = per_vendor_skills()
    for name in names:
        with open(divergence_snapshot_path(name), "w", encoding="utf-8") as fh:
            fh.write(practice_divergence(name))
        print("updated %s" % divergence_snapshot_path(name))
    if not names:
        print("no per-vendor practice skills found — nothing to snapshot")
    return 0


def main():
    if "--update-divergence" in sys.argv:
        return update_divergence_snapshots()
    global _VAULT
    sb = tempfile.mkdtemp(prefix="kb-install-sb-")
    os.environ["XDG_CONFIG_HOME"] = os.path.join(sb, "xdg")  # sandbox the engine<->installer config file
    for k in [k for k in list(os.environ) if k == "KB_VAULT" or k.endswith("_KB_VAULT")]:
        os.environ.pop(k, None)  # deterministic vault resolution: only the recorded config file decides
    _VAULT = os.path.join(sb, "vault")
    dest = tempfile.mkdtemp(prefix="kb-install-")
    try:
        r = run(["--dest", dest])
        check("install exits 0", r.returncode == 0, r.stderr)
        for n in NAMES:
            c = os.path.join(dest, ".claude", "skills", n, "SKILL.md")
            x = os.path.join(dest, ".agents", "skills", n, "SKILL.md")
            check("%s: Claude == Codex" % n,
                  os.path.isfile(c) and os.path.isfile(x) and read(dest, ".claude", n) == read(dest, ".agents", n))

        snap = {n: read(dest, ".claude", n) for n in NAMES}
        run(["--dest", dest])
        check("idempotent re-run", all(read(dest, ".claude", n) == snap[n] for n in NAMES))

        # ---- family-level maintenance skill: byte-identical multi-file deploy + baked @-tokens (W6) ----
        MAINT = "metacognition-maintenance"
        msrc = os.path.join(ROOT, "skills", MAINT)
        MFILES = sorted(os.path.relpath(os.path.join(dp, f), msrc)
                        for dp, _, fs in os.walk(msrc) for f in fs if not f.startswith("."))

        def mread(d, provider, rel):
            return open(os.path.join(d, provider, "skills", MAINT, rel), encoding="utf-8").read()

        deployed_both = all(os.path.isfile(os.path.join(dest, pr, "skills", MAINT, rel))
                            for rel in MFILES for pr in RUNTIME_DIRS)
        check("maintenance: every file deployed to runtime dirs, byte-identical",
              deployed_both and all(mread(dest, ".claude", rel) == mread(dest, pr, rel)
                                    for rel in MFILES for pr in RUNTIME_DIRS),
              "files=%s" % MFILES)
        all_text = "".join(mread(dest, ".claude", rel) for rel in MFILES)
        check("maintenance: no unbaked @TOKEN@ remains in any deployed file",
              not re.search(r"@[A-Z_]+@", all_text), re.findall(r"@[A-Z_]+@", all_text)[:5])
        # every @-token's baked VALUE is present (catches a WRONGLY-substituted token, which the
        # no-leftover-raw-token check above cannot — it only catches an UNsubstituted one).
        expected_vals = [os.path.join(ROOT, "engine", "kb-engine"), os.path.join(ROOT, "config"),
                         os.path.abspath(_VAULT), os.path.join(ROOT, "SOURCES.md"),
                         os.path.join(ROOT, "scripts", "health-check"), os.path.join(ROOT, "scripts", "no-net-loss"),
                         os.path.join(ROOT, "FAMILY.md"), ROOT]
        check("maintenance: every @-token baked to its real absolute path",
              all(v in all_text for v in expected_vals), str([v for v in expected_vals if v not in all_text]))
        # nothing-runs-unattended: BOTH providers ship exactly SKILL.md + references/ — no scheduler/trigger
        def shipped_set(provider):
            sd = os.path.join(dest, provider, "skills", MAINT)
            return sorted(os.path.relpath(os.path.join(dp, f), sd) for dp, _, fs in os.walk(sd) for f in fs)
        check("maintenance: runtime dirs ship only SKILL.md + references (no scheduler/auto-trigger artifact)",
              all(shipped_set(pr) == MFILES for pr in RUNTIME_DIRS)
              and any(f.startswith("references/") for f in MFILES) and "SKILL.md" in MFILES,
              "%s" % {pr: shipped_set(pr) for pr in RUNTIME_DIRS})
        # the maintenance frontmatter is shipped as-is (not rendered+quoted like KB adapters) — guard
        # that it stays valid+discoverable: name + description present, and an UNQUOTED description has
        # no ': ' colon-space (strict-invalid YAML that would silently break discovery).
        fm = mread(dest, ".claude", "SKILL.md").split("---", 2)[1]
        nm = [l for l in fm.splitlines() if l.startswith("name:")]
        ds = [l for l in fm.splitlines() if l.startswith("description:")]
        dval = ds[0][len("description:"):].strip() if ds else ""
        check("maintenance: deployed frontmatter valid+discoverable (name+description, no unquoted colon-space)",
              bool(nm and nm[0][len("name:"):].strip()) and bool(dval) and (dval.startswith('"') or ": " not in dval),
              fm[:160])
        snap_m = {rel: mread(dest, ".claude", rel) for rel in MFILES}
        run(["--dest", dest])
        check("maintenance: idempotent re-run", all(mread(dest, ".claude", rel) == snap_m[rel] for rel in MFILES))

        # a renamed/removed reference must not linger — the multi-file deploy prunes orphans to source
        d_pr = tempfile.mkdtemp(prefix="kb-install-")
        try:
            run(["--dest", d_pr, "--only", MAINT])
            orphan = os.path.join(d_pr, ".claude", "skills", MAINT, "references", "_orphan_selftest.md")
            open(orphan, "w").write("stale orphan reference")
            run(["--dest", d_pr, "--only", MAINT])
            check("maintenance: re-install prunes an orphan reference (deploy == source)", not os.path.exists(orphan))
        finally:
            shutil.rmtree(d_pr, ignore_errors=True)

        # `--only metacognition-maintenance` deploys ONLY the maintenance skill (no sibling adapters)
        d_m = tempfile.mkdtemp(prefix="kb-install-")
        try:
            rm = run(["--dest", d_m, "--only", MAINT])
            sdir = os.path.join(d_m, ".claude", "skills")
            present = sorted(os.listdir(sdir)) if os.path.isdir(sdir) else []
            check("--only maintenance: deploys just the maintenance skill",
                  rm.returncode == 0 and present == [MAINT], "%s / %s" % (rm.stderr.strip(), present))
        finally:
            shutil.rmtree(d_m, ignore_errors=True)

        # a surgical `--only <sibling>` must NOT deploy the family-level maintenance skill
        d_surgm = tempfile.mkdtemp(prefix="kb-install-")
        try:
            run(["--dest", d_surgm, "--only", "tool-design"])
            check("--only sibling: maintenance skill left untouched (surgical)",
                  not os.path.isdir(os.path.join(d_surgm, ".claude", "skills", MAINT)))
        finally:
            shutil.rmtree(d_surgm, ignore_errors=True)

        # an unbakeable @TOKEN@ in a maintenance file -> clean error (never ship a broken path)
        bogus = os.path.join(msrc, "references", "_selftest_bogus.md")
        open(bogus, "w").write("this references @BOGUS_TOKEN@ which no installer token resolves\n")
        d_bog = tempfile.mkdtemp(prefix="kb-install-")
        try:
            rb = run(["--dest", d_bog, "--only", MAINT])
            check("maintenance: unbaked token -> clean error (no traceback)",
                  rb.returncode != 0 and "unbaked token" in rb.stderr and "Traceback" not in rb.stderr, rb.stderr)
        finally:
            os.remove(bogus)
            shutil.rmtree(d_bog, ignore_errors=True)

        # ---- family-level freshness skill: token-baked multi-file deploy + bundled check script ----
        FRESH = "metacognition-freshness"
        fsrc = os.path.join(ROOT, "skills", FRESH)
        FFILES = sorted(os.path.relpath(os.path.join(dp, f), fsrc)
                        for dp, _, fs in os.walk(fsrc) for f in fs if not f.startswith("."))

        def fread(d, provider, rel):
            return open(os.path.join(d, provider, "skills", FRESH, rel), encoding="utf-8").read()

        deployed_fresh = all(os.path.isfile(os.path.join(dest, pr, "skills", FRESH, rel))
                             for rel in FFILES for pr in RUNTIME_DIRS)
        check("freshness: every file deployed to runtime dirs, byte-identical",
              deployed_fresh and all(fread(dest, ".claude", rel) == fread(dest, pr, rel)
                                     for rel in FFILES for pr in RUNTIME_DIRS),
              "files=%s" % FFILES)
        all_fresh = "".join(fread(dest, ".claude", rel) for rel in FFILES)
        check("freshness: no unbaked @TOKEN@ remains in any deployed file",
              not re.search(r"@[A-Z_]+@", all_fresh), re.findall(r"@[A-Z_]+@", all_fresh)[:5])
        check("freshness: repo and vault paths baked into deployed files",
              ROOT in all_fresh and os.path.abspath(_VAULT) in all_fresh,
              "missing ROOT/vault")
        d_f = tempfile.mkdtemp(prefix="kb-install-")
        try:
            rf = run(["--dest", d_f, "--only", FRESH])
            sdir = os.path.join(d_f, ".claude", "skills")
            present = sorted(os.listdir(sdir)) if os.path.isdir(sdir) else []
            check("--only freshness: deploys just the freshness skill",
                  rf.returncode == 0 and present == [FRESH], "%s / %s" % (rf.stderr.strip(), present))
        finally:
            shutil.rmtree(d_f, ignore_errors=True)

        # ---- practice-skill lane: per-provider SKILL.md + provider-neutral activation ----
        PRACTICE = ["handoff", "compact-focus"]
        psrc = os.path.join(ROOT, "skills", "practice")

        def baked(t):
            return t.replace("@VAULT@", os.path.abspath(_VAULT))

        d_ps = tempfile.mkdtemp(prefix="kb-install-")
        try:
            r = run(["--dest", d_ps])
            check("practice: install exits 0", r.returncode == 0, r.stderr)
            for name in PRACTICE:
                c = os.path.join(d_ps, ".claude", "skills", name, "SKILL.md")
                x = os.path.join(d_ps, ".agents", "skills", name, "SKILL.md")
                check("practice %s: deployed to both providers" % name, os.path.isfile(c) and os.path.isfile(x))
                # each provider gets ITS OWN per-provider body, == its source with @VAULT@ baked
                csrc = open(os.path.join(psrc, name, "claude", "SKILL.md"), encoding="utf-8").read()
                xsrc = open(os.path.join(psrc, name, "codex", "SKILL.md"), encoding="utf-8").read()
                check("practice %s: Claude deploy == claude/ source (baked)" % name,
                      os.path.isfile(c) and read(d_ps, ".claude", name) == baked(csrc))
                check("practice %s: Codex deploy == codex/ source (baked)" % name,
                      os.path.isfile(x) and read(d_ps, ".agents", name) == baked(xsrc))
            # semantic per-runtime gate: a Codex body carries no Claude-only primitive — neither the
            # $ARGUMENTS substitution nor a `/compact <focus>` argument form Codex's /compact rejects
            check("practice gate: no $ARGUMENTS or '/compact <focus>' in any Codex body",
                  all("$ARGUMENTS" not in read(d_ps, ".agents", n) and "/compact <focus>" not in read(d_ps, ".agents", n)
                      for n in PRACTICE))
            # @VAULT@ baked: no leftover @TOKEN@ in any deployed body; the baked path is present
            allp = "".join(read(d_ps, pr, n) for n in PRACTICE for pr in (".claude", ".agents"))
            check("practice: @VAULT@ baked, no leftover @TOKEN@", not re.search(r"@[A-Z_]+@", allp),
                  re.findall(r"@[A-Z_]+@", allp)[:5])
            check("practice: baked vault path present in a deployed body", os.path.abspath(_VAULT) in allp)
            # activation: both spans upserted into the shared AGENTS.md, provider-neutral
            agp = open(os.path.join(d_ps, "AGENTS.md"), encoding="utf-8").read()
            check("practice: <handoff> + <compaction> spans in AGENTS.md",
                  bool(re.search(r"^<handoff>$", agp, re.M)) and bool(re.search(r"^<compaction>$", agp, re.M)))
            check("practice: activation provider-neutral (no 'On Claude')", "On Claude" not in agp)
            # idempotent re-run (bodies + AGENTS.md)
            snap = {n: read(d_ps, ".claude", n) for n in PRACTICE}
            run(["--dest", d_ps])
            check("practice: idempotent re-run (bodies)", all(read(d_ps, ".claude", n) == snap[n] for n in PRACTICE))
            check("practice: idempotent re-run (AGENTS.md)",
                  open(os.path.join(d_ps, "AGENTS.md"), encoding="utf-8").read() == agp)
        finally:
            shutil.rmtree(d_ps, ignore_errors=True)

        # divergence gate: every per-vendor skill's LIVE divergence equals its committed golden
        # snapshot — drift in EITHER direction (gratuitous growth, or a reconciled shrink) fails,
        # forcing a conscious reconcile-toward-shared or re-snapshot. Runs over the real source tree
        # BEFORE any temp probe skill is created below, so it governs only the shipped per-vendor set.
        pv = per_vendor_skills()
        check("practice gate: per-vendor set is exactly {handoff, compact-focus}",
              pv == ["compact-focus", "handoff"], "%s" % pv)
        for name in pv:
            gp = divergence_snapshot_path(name)
            golden = open(gp, encoding="utf-8").read() if os.path.isfile(gp) else None
            check("practice gate: %s divergence == golden snapshot" % name,
                  golden is not None and practice_divergence(name) == golden,
                  "missing/stale skills/practice/%s/vendor-divergence — ./scripts/install-selftest --update-divergence" % name)

        # shared-body lane: a single <name>/SKILL.md (no provider dirs) deploys byte-identical to both
        shared = os.path.join(psrc, "_selftest_shared")
        os.makedirs(shared)
        open(os.path.join(shared, "SKILL.md"), "w").write(
            "---\nname: _selftest_shared\ndescription: shared probe\n---\n\nshared body resolving @VAULT@\n")
        open(os.path.join(shared, "agents.md"), "w").write("<_selftest_shared>\nshared trigger\n</_selftest_shared>\n")
        d_sh = tempfile.mkdtemp(prefix="kb-install-")
        try:
            r = run(["--dest", d_sh, "--only", "_selftest_shared"])
            cok = os.path.isfile(os.path.join(d_sh, ".claude", "skills", "_selftest_shared", "SKILL.md"))
            xok = os.path.isfile(os.path.join(d_sh, ".agents", "skills", "_selftest_shared", "SKILL.md"))
            check("practice shared-body: one SKILL.md deploys byte-identical to both providers (@VAULT@ baked)",
                  r.returncode == 0 and cok and xok
                  and read(d_sh, ".claude", "_selftest_shared") == read(d_sh, ".agents", "_selftest_shared")
                  and os.path.abspath(_VAULT) in read(d_sh, ".claude", "_selftest_shared"), r.stderr)
        finally:
            shutil.rmtree(d_sh, ignore_errors=True)
            shutil.rmtree(shared, ignore_errors=True)

        # ambiguous layout: a shared SKILL.md AND a per-provider dir together -> clean error
        amb = os.path.join(psrc, "_selftest_ambig")
        os.makedirs(os.path.join(amb, "claude"))
        open(os.path.join(amb, "SKILL.md"), "w").write("---\nname: x\ndescription: y\n---\n\nshared\n")
        open(os.path.join(amb, "claude", "SKILL.md"), "w").write("---\nname: x\ndescription: y\n---\n\nclaude\n")
        open(os.path.join(amb, "agents.md"), "w").write("<x>\nt\n</x>\n")
        d_amb = tempfile.mkdtemp(prefix="kb-install-")
        try:
            rb = run(["--dest", d_amb, "--only", "_selftest_ambig"])
            check("practice ambiguous layout (shared + per-provider) -> clean error",
                  rb.returncode != 0 and "pick one layout" in rb.stderr and "Traceback" not in rb.stderr, rb.stderr)
        finally:
            shutil.rmtree(d_amb, ignore_errors=True)
            shutil.rmtree(amb, ignore_errors=True)

        # set-keyed: a NEW skills/practice/<x>/ dir deploys with no install code change
        probe = os.path.join(psrc, "_selftest_probe")
        os.makedirs(os.path.join(probe, "claude"))
        os.makedirs(os.path.join(probe, "codex"))
        open(os.path.join(probe, "claude", "SKILL.md"), "w").write("---\nname: _selftest_probe\ndescription: probe\n---\n\nclaude body\n")
        open(os.path.join(probe, "codex", "SKILL.md"), "w").write("---\nname: _selftest_probe\ndescription: probe\ncompatibility: Designed for Codex\n---\n\ncodex body\n")
        open(os.path.join(probe, "agents.md"), "w").write("<_selftest_probe>\nprobe trigger\n</_selftest_probe>\n")
        d_set = tempfile.mkdtemp(prefix="kb-install-")
        try:
            r = run(["--dest", d_set, "--only", "_selftest_probe"])
            check("practice set-keyed: a new dir deploys with no code change",
                  r.returncode == 0
                  and os.path.isfile(os.path.join(d_set, ".claude", "skills", "_selftest_probe", "SKILL.md"))
                  and os.path.isfile(os.path.join(d_set, ".agents", "skills", "_selftest_probe", "SKILL.md")), r.stderr)
        finally:
            shutil.rmtree(d_set, ignore_errors=True)
            shutil.rmtree(probe, ignore_errors=True)

        # an unbakeable @TOKEN@ in a practice body -> clean error (never ship a broken path)
        badp = os.path.join(psrc, "_selftest_badtoken")
        os.makedirs(os.path.join(badp, "claude"))
        os.makedirs(os.path.join(badp, "codex"))
        open(os.path.join(badp, "claude", "SKILL.md"), "w").write("---\nname: x\ndescription: y\n---\n\nrefs @BOGUS_TOKEN@\n")
        open(os.path.join(badp, "codex", "SKILL.md"), "w").write("---\nname: x\ndescription: y\n---\n\nok\n")
        open(os.path.join(badp, "agents.md"), "w").write("<x>\nt\n</x>\n")
        d_bt = tempfile.mkdtemp(prefix="kb-install-")
        try:
            rb = run(["--dest", d_bt, "--only", "_selftest_badtoken"])
            check("practice: unbaked token -> clean error (no traceback)",
                  rb.returncode != 0 and "unbaked token" in rb.stderr and "Traceback" not in rb.stderr, rb.stderr)
        finally:
            shutil.rmtree(d_bt, ignore_errors=True)
            shutil.rmtree(badp, ignore_errors=True)

        # `--only <practice-name>` deploys ONLY that practice skill (no siblings, no maintenance)
        d_op = tempfile.mkdtemp(prefix="kb-install-")
        try:
            rp = run(["--dest", d_op, "--only", "handoff"])
            sdir = os.path.join(d_op, ".claude", "skills")
            present = sorted(os.listdir(sdir)) if os.path.isdir(sdir) else []
            check("--only handoff: deploys just that practice skill",
                  rp.returncode == 0 and present == ["handoff"], "%s / %s" % (rp.stderr.strip(), present))
        finally:
            shutil.rmtree(d_op, ignore_errors=True)

        # a surgical `--only <sibling>` leaves the practice skills untouched
        d_sp = tempfile.mkdtemp(prefix="kb-install-")
        try:
            run(["--dest", d_sp, "--only", "tool-design"])
            check("--only sibling: practice skills left untouched",
                  not os.path.isdir(os.path.join(d_sp, ".claude", "skills", "handoff"))
                  and not os.path.isdir(os.path.join(d_sp, ".claude", "skills", "compact-focus")))
        finally:
            shutil.rmtree(d_sp, ignore_errors=True)

        # activation upsert is surgical: takes over a pre-existing <handoff> span, preserves neighbours
        d_surgp = tempfile.mkdtemp(prefix="kb-install-")
        try:
            agp2 = os.path.join(d_surgp, "AGENTS.md")
            open(agp2, "w", encoding="utf-8").write(
                "<user_sentinel>\nkeep me\n</user_sentinel>\n\n"
                "<handoff>\nSTALE HANDOFF\n</handoff>\n\n"
                "<closing_sentinel>\nkeep me too\n</closing_sentinel>\n")
            run(["--dest", d_surgp, "--only", "handoff"])
            out = open(agp2, encoding="utf-8").read()
            check("practice surgical: user blocks preserved",
                  "<user_sentinel>\nkeep me\n</user_sentinel>" in out and "<closing_sentinel>\nkeep me too\n</closing_sentinel>" in out)
            check("practice surgical: stale handoff replaced in place",
                  "STALE HANDOFF" not in out and bool(re.search(r"^<handoff>$", out, re.M))
                  and out.index("<handoff>") < out.index("<closing_sentinel>"))
        finally:
            shutil.rmtree(d_surgp, ignore_errors=True)

        # the installer docstring documents the practice-skill lane
        instxt = open(INSTALL, encoding="utf-8").read()
        check("install docstring documents the practice-skill lane",
              "five things" in instxt and "skills/practice" in instxt)

        d2 = tempfile.mkdtemp(prefix="kb-install-")
        try:
            r = run(["--dest", d2, "--only", "context-engineering-knowledge-base"])
            check("--only accepts full skill name",
                  r.returncode == 0 and os.path.isfile(os.path.join(d2, ".claude", "skills", NAMES[0], "SKILL.md")), r.stderr)
        finally:
            shutil.rmtree(d2, ignore_errors=True)

        r = run(["--dest", dest, "--only", "nonsuch"])
        check("unknown --only: clean error", r.returncode != 0 and "unknown sibling" in r.stderr and "Traceback" not in r.stderr, r.stderr)

        # stray dotfile in config/ must be skipped, not aborted on
        ds = os.path.join(CONFIG, ".DS_Store")
        open(ds, "w").write("junk")
        try:
            d3 = tempfile.mkdtemp(prefix="kb-install-")
            try:
                r = run(["--dest", d3])
                installed = sorted(os.listdir(os.path.join(d3, ".claude", "skills"))) if os.path.isdir(os.path.join(d3, ".claude", "skills")) else []
                # Intent: the stray dotfile is skipped, never mis-treated as a sibling. Asserted
                # robustly (not `== NAMES`, which is stale now config/ holds >3 siblings + the
                # family-level maintenance skill): the known siblings + maintenance are present and
                # NO entry derives from the dotfile.
                check("stray .DS_Store skipped",
                      r.returncode == 0 and set(NAMES) <= set(installed) and "metacognition-maintenance" in installed
                      and not any(s.startswith(".") or "DS_Store" in s for s in installed),
                      "%s / %s" % (r.stderr.strip(), installed))
            finally:
                shutil.rmtree(d3, ignore_errors=True)
        finally:
            os.remove(ds)

        # config missing a required field -> clean error
        bad = os.path.join(CONFIG, "_selftest_bad")
        open(bad, "w").write("index_heading = X\n")  # no stem
        try:
            r = run(["--dest", dest, "--only", "_selftest_bad"])
            check("missing config field: clean error",
                  r.returncode != 0 and "missing required field" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        finally:
            os.remove(bad)

        # config present but no wiring description -> clean error
        nw = os.path.join(CONFIG, "_selftest_nowire")
        open(nw, "w").write("stem = _selftest_nowire\nindex_heading = X\n")
        try:
            r = run(["--dest", dest, "--only", "_selftest_nowire"])
            check("missing description: clean error",
                  r.returncode != 0 and "discovery description" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        finally:
            os.remove(nw)

        # a description with ': ', '"', and '\' renders as a valid (quoted + escaped) YAML scalar —
        # an unquoted ': ' is strict-invalid YAML (and shipped in 2/3 live adapters before this fix).
        yt = os.path.join(CONFIG, "_selftest_yaml")
        wyt = os.path.join(ROOT, "wiring", "_selftest_yaml")
        open(yt, "w").write("stem = _selftest_yaml\nindex_heading = X\ntier = situational\n")
        open(wyt, "w").write('description = colon: here, a "quote", and a \\ slash\n')
        d_y = tempfile.mkdtemp(prefix="kb-install-")
        try:
            run(["--dest", d_y, "--only", "_selftest_yaml"])
            line = next(l for l in read(d_y, ".claude", "_selftest_yaml-knowledge-base").splitlines()
                        if l.startswith("description:"))
            check("description rendered as a quoted+escaped YAML scalar",
                  line == r'description: "colon: here, a \"quote\", and a \\ slash"', line)
        finally:
            os.remove(yt)
            os.remove(wyt)
            shutil.rmtree(d_y, ignore_errors=True)

        # ---- tier-gated AGENTS.md trigger-block emission ----
        def expected_block(stem):
            body = open(os.path.join(ROOT, "wiring", stem + ".agents.md"), encoding="utf-8").read()
            tag = stem.replace("-", "_")
            return "<%s>\n%s</%s>" % (tag, body, tag)

        CE = expected_block("context-engineering")
        PE = expected_block("prompt-engineering")

        # everyday siblings -> block emitted byte-exact into the shared AGENTS.md; idempotent
        d_ev = tempfile.mkdtemp(prefix="kb-install-")
        try:
            run(["--dest", d_ev])
            ag = os.path.join(d_ev, "AGENTS.md")
            txt = open(ag, encoding="utf-8").read() if os.path.isfile(ag) else ""
            check("everyday: AGENTS.md created", os.path.isfile(ag))
            check("everyday: CE block byte-exact", CE in txt)
            check("everyday: PE block byte-exact", PE in txt)
            check("everyday: no situational block", "<tool_design>" not in txt)
            run(["--dest", d_ev])
            check("AGENTS.md idempotent re-run", os.path.isfile(ag) and open(ag, encoding="utf-8").read() == txt)
        finally:
            shutil.rmtree(d_ev, ignore_errors=True)

        # situational-only target writes NO AGENTS.md at all
        d_sit = tempfile.mkdtemp(prefix="kb-install-")
        try:
            run(["--dest", d_sit, "--only", "tool-design"])
            check("situational --only: no AGENTS.md", not os.path.isfile(os.path.join(d_sit, "AGENTS.md")))
        finally:
            shutil.rmtree(d_sit, ignore_errors=True)

        # --only an everyday sibling emits ONLY that block
        d_one = tempfile.mkdtemp(prefix="kb-install-")
        try:
            run(["--dest", d_one, "--only", "context-engineering"])
            txt = open(os.path.join(d_one, "AGENTS.md"), encoding="utf-8").read()
            check("--only CE: CE block present", CE in txt)
            check("--only CE: PE block absent", "<prompt_engineering>" not in txt)
        finally:
            shutil.rmtree(d_one, ignore_errors=True)

        # surgical upsert: replace the named block in place, leave every other span untouched
        d_surg = tempfile.mkdtemp(prefix="kb-install-")
        try:
            ag = os.path.join(d_surg, "AGENTS.md")
            open(ag, "w", encoding="utf-8").write(
                "<user_sentinel>\nhand-written, must survive\n</user_sentinel>\n\n"
                "<context_engineering>\nSTALE BODY\n</context_engineering>\n\n"
                "<closing_sentinel>\nalso keep\n</closing_sentinel>\n")
            run(["--dest", d_surg, "--only", "context-engineering"])
            out = open(ag, encoding="utf-8").read()
            check("surgical: leading user block preserved", "<user_sentinel>\nhand-written, must survive\n</user_sentinel>" in out)
            check("surgical: trailing user block preserved", "<closing_sentinel>\nalso keep\n</closing_sentinel>" in out)
            check("surgical: stale block replaced by canonical", CE in out and "STALE BODY" not in out)
            check("surgical: block replaced in place (not appended)",
                  out.index("<context_engineering>") < out.index("<closing_sentinel>"))
        finally:
            shutil.rmtree(d_surg, ignore_errors=True)

        # surgical upsert must NOT swallow a neighbour block that merely MENTIONS the tag inline
        d_p8 = tempfile.mkdtemp(prefix="kb-install-")
        try:
            ag = os.path.join(d_p8, "AGENTS.md")
            open(ag, "w", encoding="utf-8").write(
                "<note>\nSee the <context_engineering> idea inline.\n</note>\n\n"
                "<context_engineering>\nSTALE\n</context_engineering>\n")
            run(["--dest", d_p8, "--only", "context-engineering"])
            out = open(ag, encoding="utf-8").read()
            check("inline tag mention: neighbour block intact",
                  "<note>\nSee the <context_engineering> idea inline.\n</note>" in out)
            check("inline tag mention: real block still replaced", CE in out and "STALE" not in out)
        finally:
            shutil.rmtree(d_p8, ignore_errors=True)

        # a body that embeds its own closing tag -> clean error (would otherwise break idempotency)
        bc = os.path.join(CONFIG, "_selftest_badbody")
        wbc = os.path.join(ROOT, "wiring", "_selftest_badbody")
        wbcb = os.path.join(ROOT, "wiring", "_selftest_badbody.agents.md")
        open(bc, "w").write("stem = _selftest_badbody\nindex_heading = X\ntier = everyday\n")
        open(wbc, "w").write("description = probe\n")
        open(wbcb, "w").write("hello </_selftest_badbody> world\n")
        try:
            r = run(["--dest", dest, "--only", "_selftest_badbody"])
            check("body with embedded close tag: clean error",
                  r.returncode != 0 and "closing tag" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        finally:
            os.remove(bc)
            os.remove(wbc)
            os.remove(wbcb)

        # a body's trailing-newline shape is normalised to exactly one
        d_nl = tempfile.mkdtemp(prefix="kb-install-")
        nlc = os.path.join(CONFIG, "_selftest_nl")
        wnl = os.path.join(ROOT, "wiring", "_selftest_nl")
        wnlb = os.path.join(ROOT, "wiring", "_selftest_nl.agents.md")
        open(nlc, "w").write("stem = _selftest_nl\nindex_heading = X\ntier = everyday\n")
        open(wnl, "w").write("description = probe\n")
        open(wnlb, "w").write("LINE ONE\nLINE TWO\n\n\n")  # 3 trailing newlines
        try:
            run(["--dest", d_nl, "--only", "_selftest_nl"])
            out = open(os.path.join(d_nl, "AGENTS.md"), encoding="utf-8").read()
            check("body trailing-newlines normalised to one",
                  "<_selftest_nl>\nLINE ONE\nLINE TWO\n</_selftest_nl>" in out)
        finally:
            os.remove(nlc)
            os.remove(wnl)
            os.remove(wnlb)
            shutil.rmtree(d_nl, ignore_errors=True)

        # a typo'd tier -> clean error (never silently drop an Everyday block)
        tt = os.path.join(CONFIG, "_selftest_tier_typo")
        wtt = os.path.join(ROOT, "wiring", "_selftest_tier_typo")
        open(tt, "w").write("stem = _selftest_tier_typo\nindex_heading = X\ntier = everydy\n")
        open(wtt, "w").write("description = probe\n")
        try:
            r = run(["--dest", dest, "--only", "_selftest_tier_typo"])
            check("tier typo: clean error",
                  r.returncode != 0 and "must be one of" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        finally:
            os.remove(tt)
            os.remove(wtt)

        # tier=everyday but no trigger-block file -> clean error
        bk = os.path.join(CONFIG, "_selftest_everyday_noblock")
        wbk = os.path.join(ROOT, "wiring", "_selftest_everyday_noblock")
        open(bk, "w").write("stem = _selftest_everyday_noblock\nindex_heading = X\ntier = everyday\n")
        open(wbk, "w").write("description = probe\n")
        try:
            r = run(["--dest", dest, "--only", "_selftest_everyday_noblock"])
            check("everyday w/o block file: clean error",
                  r.returncode != 0 and "trigger block" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        finally:
            os.remove(bk)
            os.remove(wbk)

        # ---- vault git-init (repo root) + location recorded + engine resolves it ----
        conf = os.path.join(os.environ["XDG_CONFIG_HOME"], "metacognition", "vault")
        top = subprocess.run(["git", "-C", _VAULT, "rev-parse", "--show-toplevel"], capture_output=True, text=True)
        check("vault git-inited as a repo root",
              top.returncode == 0 and os.path.realpath(top.stdout.strip()) == os.path.realpath(_VAULT), top.stderr)
        check("vault location recorded for the engine",
              os.path.isfile(conf) and open(conf, encoding="utf-8").read().strip() == os.path.abspath(_VAULT))
        eng = subprocess.run([sys.executable, ENGINE, "--config", os.path.join(CONFIG, "context-engineering"), "locate"],
                             capture_output=True, text=True)
        resolved = next((ln.split(":", 1)[1].strip() for ln in eng.stdout.splitlines() if ln.startswith("vault:")), "")
        check("engine resolves the recorded vault (no --vault/env)",
              eng.returncode == 0 and resolved == os.path.abspath(_VAULT), (eng.stdout + eng.stderr).strip())
        before = open(conf, encoding="utf-8").read()
        run(["--dest", dest])
        check("re-install idempotent (recorded vault unchanged)", open(conf, encoding="utf-8").read() == before)
        # an absent vault dir is created + git-inited (the fresh-setup, non-clone path)
        fresh = os.path.join(sb, "fresh-vault")
        rf = run(["--dest", dest, "--vault", fresh, "--only", "tool-design"])
        topf = subprocess.run(["git", "-C", fresh, "rev-parse", "--show-toplevel"], capture_output=True, text=True)
        check("absent vault is created + git-inited",
              rf.returncode == 0 and topf.returncode == 0
              and os.path.realpath(topf.stdout.strip()) == os.path.realpath(fresh), rf.stderr)
        # a vault path that is a file -> clean error (no traceback)
        ff = os.path.join(sb, "vault-is-a-file")
        open(ff, "w").write("x")
        rbv = run(["--dest", dest, "--only", "tool-design", "--vault", ff])
        check("vault-is-a-file clean error",
              rbv.returncode != 0 and "not a directory" in rbv.stderr and "Traceback" not in rbv.stderr, rbv.stderr)
        # a vault NESTED in an outer repo is re-rooted as its OWN root (no commit can escape upward)
        outer = os.path.join(sb, "outer")
        nested = os.path.join(outer, "vault")
        os.makedirs(nested)
        subprocess.run(["git", "-C", outer, "init", "-q"], capture_output=True)
        before = subprocess.run(["git", "-C", nested, "rev-parse", "--show-toplevel"], capture_output=True, text=True).stdout.strip()
        run(["--dest", dest, "--only", "tool-design", "--vault", nested])
        topn = subprocess.run(["git", "-C", nested, "rev-parse", "--show-toplevel"], capture_output=True, text=True)
        check("nested vault re-rooted (no commit escapes to the enclosing repo)",
              os.path.realpath(before) == os.path.realpath(outer)  # the vault really resolved UP to the outer repo before
              and topn.returncode == 0 and os.path.realpath(topn.stdout.strip()) == os.path.realpath(nested),  # now its own root
              "before=%s topn=%s" % (before, (topn.stdout + topn.stderr).strip()))

        # ---- optional local pre-commit hook setup UX ---------------------------------------------
        hook_root = os.path.join(sb, "hook-install-repo")
        hook_install = copy_install_repo(hook_root)

        def run_hook_install(extra):
            return subprocess.run([sys.executable, hook_install, "--dest", os.path.join(hook_root, "dest"),
                                   "--vault", os.path.join(hook_root, "vault"), *extra],
                                  cwd=hook_root, capture_output=True, text=True)

        r = run_hook_install([])
        hook = os.path.join(hook_root, ".git", "hooks", "pre-commit")
        check("pre-commit setup: non-interactive install skips by default",
              r.returncode == 0 and not os.path.exists(hook) and "not installed" in r.stdout, r.stderr)
        r = run_hook_install(["--install-pre-commit"])
        hook_text = open(hook, encoding="utf-8").read() if os.path.isfile(hook) else ""
        check("pre-commit setup: explicit flag installs the managed hook",
              r.returncode == 0 and os.path.isfile(hook) and os.access(hook, os.X_OK)
              and "metacognition selftest-gate sentinel" in hook_text
              and "rev-parse --local-env-vars" in hook_text, r.stderr)

        hook_root_existing = os.path.join(sb, "hook-install-existing")
        hook_install_existing = copy_install_repo(hook_root_existing)
        hook_existing = os.path.join(hook_root_existing, ".git", "hooks", "pre-commit")
        os.makedirs(os.path.dirname(hook_existing), exist_ok=True)
        original_hook = "#!/bin/sh\necho existing hook\n"
        with open(hook_existing, "w", encoding="utf-8") as fh:
            fh.write(original_hook)
        os.chmod(hook_existing, 0o755)
        r = subprocess.run([sys.executable, hook_install_existing, "--dest", os.path.join(hook_root_existing, "dest"),
                            "--vault", os.path.join(hook_root_existing, "vault"), "--install-pre-commit"],
                           cwd=hook_root_existing, capture_output=True, text=True)
        preserved = os.path.join(hook_root_existing, ".git", "hooks", "pre-commit.metacognition-existing")
        wrapper = open(hook_existing, encoding="utf-8").read() if os.path.isfile(hook_existing) else ""
        check("pre-commit setup: existing unmanaged hook is preserved and chained",
              r.returncode == 0 and os.path.isfile(preserved)
              and open(preserved, encoding="utf-8").read() == original_hook
              and "pre-commit.metacognition-existing" in wrapper
              and "metacognition selftest-gate sentinel" in wrapper
              and "rev-parse --local-env-vars" in wrapper, r.stderr)
    finally:
        shutil.rmtree(dest, ignore_errors=True)
        shutil.rmtree(sb, ignore_errors=True)

    passed, total = sum(_ok), len(_ok)
    print("\n%s: %d/%d checks passed" % ("PASS" if passed == total else "FAIL", passed, total))
    return 0 if passed == total else 1


if __name__ == "__main__":
    raise SystemExit(main())

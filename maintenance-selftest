#!/usr/bin/env python3
"""maintenance-selftest — behavioral tests for the propose->ratify spine the
metacognition-maintenance skill drives (W1 of 0010-vault-self-evolution).

The skill itself is prose an agent follows; this file is the executable contract for the
deterministic git + kb-engine mechanics that prose relies on, so the spine's WHYs live here
(run after any change to the spine reference or the skill's applier procedure). It drives the
REAL kb-engine against a throwaway vault — no mock — so a drift between the documented protocol
and the engine's actual behavior fails a check here rather than in production.

Each test pins one load-bearing property of the spine:
  - PROPOSAL ISOLATION: a claim-affecting / structural change is proposed on a `proposal/...`
    worktree+branch off main, so main's HEAD and tree are untouched until the human merges. Reject
    (worktree remove + branch -D) leaves the vault byte-for-byte unchanged — no main trace, branch
    gone, working tree clean (incl. untracked). (A single claim-change MAY instead ratify via the
    lighter present-diff-then-`refresh`-on-main path — also human-gated; that prose path lives in
    propose-on-branch.md and is not exercised here.)
  - RATIFY = MERGE: merging the proposal branch applies EVERY verb commit to main — pinned on a
    multi-commit composite (both the refresh and the capture land; INDEX holds both slugs).
  - PROVENANCE + INDIVIDUALLY REVERTIBLE: each proposal commit carries the skill's Heal-* git
    trailers and keeps the engine's bare `<stem>: <verb> <slug>` subject; reverting ONE composite
    commit does not force reverting its sibling, though both touched the shared INDEX.
  - RESTARTABLE COMPOSITE: a multi-verb op — split (refresh+capture) AND merge (refresh+remove) —
    is an ordered sequence; progress is the set of verb-commits already on the branch (`git log
    main..branch`), NOT a side file. An interrupted op re-runs only the missing verbs, and a full
    re-run is a no-op — idempotent, because the engine errors on a blind retry (refresh of
    unchanged content, capture of an existing slug, remove of an ABSENT slug) and the applier
    skips by branch-log instead.
  - SINGLE WRITER: every change is one kb-engine commit; the tree is clean after each op
    (no out-of-band hand-edit) and every commit subject is engine-shaped.
  - AUTO PATH: a claim-preserving heal commits straight to main with `Heal-mode: auto` and no
    worktree. This pins the mechanical WRITE path only — the gate's CLASSIFICATION (which change
    is auto vs proposal) is skill judgment/prose, not engine code, so it is out of this harness.
  - QUARANTINE WRITE (T1, W3): a sub-bar source WITHOUT a degraded marker is refused (never written
    dirty); the SAME entry carrying a `degraded:` marker is admitted, lands one commit on main with
    the `⚠` INDEX down-rank and `Heal-verdict: degraded` provenance. Pins the degraded write through
    the skill's refresh+provenance route end-to-end (the engine's degraded-admit + ⚠ unit lives in
    engine/selftest); the route CHOICE (quarantine → proposal) is skill prose, out of this harness.
"""
import os
import re
import shutil
import subprocess
import sys
import tempfile

ENGINE = os.path.join(os.path.dirname(os.path.abspath(__file__)), "engine", "kb-engine")

_checks = []


def check(name, ok, detail=""):
    _checks.append(bool(ok))
    print("  %s %s%s" % ("PASS" if ok else "FAIL", name, ("  — " + str(detail)) if detail and not ok else ""))


def git(v, *a):
    return subprocess.run(["git", "-C", v, *a], capture_output=True, text=True)


def head(v, ref="HEAD"):
    return git(v, "rev-parse", ref).stdout.strip()


def tree_hash(v, ref="HEAD"):
    # The commit's tree object — identical tree hash == byte-for-byte identical content (reject path).
    return git(v, "rev-parse", ref + "^{tree}").stdout.strip()


INDEX_SKELETON = (
    "# Test KB — Index\n\nRead this index first, then load only matching entries.\n\n"
    "## Concepts\n\n<!-- one line per concept; appended by capture/refresh -->\n"
)
SOURCES = "# test policy\n```hosts\nexample.com\narxiv.org\n```\n"


def entry(slug, body):
    return ('---\nname: %s\ndescription: trigger for %s\nlast_refreshed: 2026-06-20\n'
            'sources:\n  - Author, "Title", 2026 — https://example.com\n---\n\n%s\n'
            % (slug, slug, body))


def make_vault(root):
    """A throwaway single-topic vault, git-initialised with one seeded entry on main — the
    starting state every spine test branches a proposal from. Mirrors engine/selftest's harness."""
    vault = os.path.join(root, "vault")
    kdir = os.path.join(vault, "test-topic", "knowledge")
    os.makedirs(kdir)
    with open(os.path.join(vault, "test-topic", "INDEX.md"), "w", encoding="utf-8") as fh:
        fh.write(INDEX_SKELETON)
    cfg = os.path.join(root, "config")
    with open(cfg, "w", encoding="utf-8") as fh:
        fh.write("stem = test-topic\nindex_heading = Concepts\nenv_prefix = CE\ntier = common\n")
    sources = os.path.join(root, "SOURCES.md")
    with open(sources, "w", encoding="utf-8") as fh:
        fh.write(SOURCES)
    git(vault, "init", "-q")
    git(vault, "config", "user.name", "selftest")
    git(vault, "config", "user.email", "selftest@example.com")
    # seed an entry on main via the engine, so 'refresh' has a target to supersede
    run(cfg, vault, sources, ["capture", "alpha"], entry("alpha", "Original body of alpha."))
    return vault, cfg, sources


def run(cfg, vault, sources, args, stdin=None):
    """Invoke the engine exactly as the skill does — --config, --vault (main OR a worktree),
    --sources. Returns the CompletedProcess."""
    cmd = [sys.executable, ENGINE, "--config", cfg, "--vault", vault, *args]
    if sources and args and args[0] in ("capture", "refresh"):
        cmd += ["--sources", sources]
    return subprocess.run(cmd, input=stdin, capture_output=True, text=True)


# --- The spine's restartable composite-op applier, encoded as the skill documents it. ---
# An op is (verb, slug, content_or_None, trailers). Progress is read from the branch's own commit
# log (main..branch) — the proposal branch IS the op-progress record, so an
# interrupted sequence re-runs only the verbs not yet committed, and a completed sequence re-runs
# to a no-op. This is what makes a blind engine retry (which would error) unnecessary.
def applied_verbs(vault, base, branch):
    out = git(vault, "log", "--format=%s", "%s..%s" % (base, branch)).stdout.splitlines()
    done = set()
    for subj in out:
        m = re.match(r"^\S+: (\S+ \S+)$", subj.strip())  # "<stem>: <verb> <slug>"
        if m:
            done.add(m.group(1))
    return done


def apply_sequence(cfg, vault_main, worktree, sources, base, branch, ops):
    """Run an ordered verb sequence on the proposal worktree, skipping verbs already committed
    on the branch. Returns the list of verbs actually invoked this pass (so a test can assert an
    interrupted run resumes, and a finished run is a no-op)."""
    done = applied_verbs(vault_main, base, branch)
    invoked = []
    for verb, slug, content, trailers in ops:
        if "%s %s" % (verb, slug) in done:
            continue  # already on the branch — idempotent skip
        args = [verb, slug]
        for k, v in trailers:
            args += ["--trailer", "%s:%s" % (k, v)]
        r = run(cfg, worktree, sources, args, content)
        if r.returncode != 0:
            raise AssertionError("verb %r %r failed: %s" % (verb, slug, r.stderr.strip()))
        invoked.append("%s %s" % (verb, slug))
    return invoked


HEAL = [("Heal-verdict", "split"), ("Heal-mode", "ratified"), ("Heal-confidence", "0.9"),
        ("Sources-before", "https://example.com"), ("Sources-after", "https://example.com"),
        ("Heal-run", "selftest-1")]


def main():
    root = tempfile.mkdtemp(prefix="mnt-selftest-")
    try:
        vault, cfg, sources = make_vault(root)
        main0 = head(vault)
        wt = os.path.join(root, "wt")

        # === PROPOSAL ISOLATION ===
        git(vault, "worktree", "add", "-q", "-b", "proposal/t1-alpha-1", wt, "main")
        check("engine accepts the worktree as its vault root",
              os.path.realpath(git(wt, "rev-parse", "--show-toplevel").stdout.strip()) == os.path.realpath(wt))
        r = run(cfg, wt, sources, ["refresh", "alpha"] + [a for k, v in HEAL for a in ("--trailer", "%s:%s" % (k, v))],
                entry("alpha", "Reconciled body of alpha — supersedes the original."))
        check("proposal verb commits on the branch", r.returncode == 0, r.stderr)
        ahead = git(vault, "rev-list", "--count", "main..proposal/t1-alpha-1").stdout.strip()
        check("exactly one new commit on the proposal branch", ahead == "1", "ahead=%s" % ahead)
        check("main HEAD unchanged before merge", head(vault) == main0)
        check("main tree clean before merge", git(vault, "status", "--porcelain").stdout.strip() == "")
        on_main = git(vault, "show", "main:test-topic/knowledge/alpha.md").stdout
        check("main still holds the ORIGINAL entry pre-merge", "Original body of alpha." in on_main, on_main[:80])

        # === PROVENANCE ===
        body = git(vault, "log", "-1", "--format=%B", "proposal/t1-alpha-1").stdout
        subj = git(vault, "log", "-1", "--format=%s", "proposal/t1-alpha-1").stdout.strip()
        check("commit subject stays the bare engine form", subj == "test-topic: refresh alpha", subj)
        check("Heal-mode trailer recorded", "Heal-mode: ratified" in body, body)
        check("Heal-verdict trailer recorded", "Heal-verdict: split" in body, body)
        check("git parses the trailers back out",
              "ratified" in git(vault, "log", "-1", "--format=%(trailers:key=Heal-mode,valueonly)",
                                "proposal/t1-alpha-1").stdout)

        # === RATIFY = MERGE ===
        m = git(vault, "merge", "-q", "--no-ff", "proposal/t1-alpha-1", "-m", "ratify: heal alpha")
        check("ratify merge succeeds", m.returncode == 0, m.stderr)
        after = git(vault, "show", "main:test-topic/knowledge/alpha.md").stdout
        check("merge applied the heal to main", "Reconciled body of alpha" in after, after[:80])
        git(vault, "worktree", "remove", "--force", wt)
        git(vault, "branch", "-q", "-d", "proposal/t1-alpha-1")
        check("ratify cleanup removes the worktree", "proposal/t1-alpha-1" not in git(vault, "worktree", "list").stdout)

        # === REJECT leaves the vault byte-for-byte unchanged ===
        pre_head, pre_tree = head(vault), tree_hash(vault)
        git(vault, "worktree", "add", "-q", "-b", "proposal/t1-beta-1", wt, "main")
        rc = run(cfg, wt, sources, ["capture", "beta", "--trailer", "Heal-mode:ratified"],
                 entry("beta", "Body of the proposed new entry beta."))
        check("proposal captures a NEW entry on the branch", rc.returncode == 0, rc.stderr)
        check("beta exists on the branch", git(wt, "cat-file", "-e", "HEAD:test-topic/knowledge/beta.md").returncode == 0)
        git(vault, "worktree", "remove", "--force", wt)
        git(vault, "branch", "-q", "-D", "proposal/t1-beta-1")
        check("reject: main HEAD unchanged", head(vault) == pre_head)
        check("reject: main tree byte-for-byte identical", tree_hash(vault) == pre_tree)
        check("reject: main worktree fully clean — no untracked leak",
              git(vault, "status", "--porcelain", "--untracked-files=all").stdout.strip() == "")
        check("reject: proposed entry never reached main",
              git(vault, "cat-file", "-e", "HEAD:test-topic/knowledge/beta.md").returncode != 0)
        check("reject: proposal branch is gone", git(vault, "rev-parse", "--verify", "proposal/t1-beta-1").returncode != 0)

        # === RESTARTABLE COMPOSITE op: split alpha into alpha' + gamma ===
        split = [
            ("refresh", "alpha", entry("alpha", "Alpha after the split — narrowed scope."), HEAL),
            ("capture", "gamma", entry("gamma", "Gamma — the half split out of alpha."), HEAL),
        ]
        git(vault, "worktree", "add", "-q", "-b", "proposal/t2-split-1", wt, "main")
        # interruption: only the first verb lands this pass
        first = apply_sequence(cfg, vault, wt, sources, "main", "proposal/t2-split-1", split[:1])
        check("interrupted run applied only the reached verb", first == ["refresh alpha"], first)
        # restart with the FULL sequence: the committed verb is skipped, the missing one runs
        resume = apply_sequence(cfg, vault, wt, sources, "main", "proposal/t2-split-1", split)
        check("restart resumes only the missing verb (idempotent skip)", resume == ["capture gamma"], resume)
        n = git(vault, "rev-list", "--count", "main..proposal/t2-split-1").stdout.strip()
        check("composite landed exactly 2 commits (no double-apply)", n == "2", "commits=%s" % n)
        # a third full pass is a complete no-op — the sequence has fully converged
        again = apply_sequence(cfg, vault, wt, sources, "main", "proposal/t2-split-1", split)
        check("a fully-applied sequence re-runs to a no-op", again == [], again)
        n2 = git(vault, "rev-list", "--count", "main..proposal/t2-split-1").stdout.strip()
        check("idempotent: no extra commits on re-run", n2 == "2", "commits=%s" % n2)

        # === SINGLE WRITER: worktree tree clean + only engine-shaped commits ===
        check("worktree tree clean after the composite (no out-of-band edit)",
              git(wt, "status", "--porcelain").stdout.strip() == "")
        subs = git(vault, "log", "--format=%s", "main..proposal/t2-split-1").stdout.splitlines()
        check("every proposal commit is engine-shaped `<stem>: <verb> <slug>`",
              all(re.match(r"^test-topic: (capture|refresh|remove) \S+$", s) for s in subs), subs)
        # RATIFY a MULTI-commit composite: the --no-ff merge applies EVERY verb commit to main
        # (the single-commit ratify above does not exercise this). Done while the branch is still
        # live in its worktree — merging from the primary checkout is unaffected by the worktree.
        gamma_sha = git(vault, "log", "-1", "--format=%H", "--grep=capture gamma", "proposal/t2-split-1").stdout.strip()
        mc = git(vault, "merge", "-q", "--no-ff", "proposal/t2-split-1", "-m", "ratify: split alpha into alpha+gamma")
        check("multi-commit composite merges to main", mc.returncode == 0, mc.stderr)
        check("merge landed the refresh verb (alpha narrowed on main)",
              "Alpha after the split" in git(vault, "show", "main:test-topic/knowledge/alpha.md").stdout)
        check("merge landed the capture verb (gamma present on main)",
              git(vault, "cat-file", "-e", "main:test-topic/knowledge/gamma.md").returncode == 0)
        idx_main = git(vault, "show", "main:test-topic/INDEX.md").stdout
        check("merge: INDEX holds BOTH composite slugs",
              "knowledge/alpha.md" in idx_main and "knowledge/gamma.md" in idx_main, idx_main)
        git(vault, "worktree", "remove", "--force", wt)
        git(vault, "branch", "-q", "-D", "proposal/t2-split-1")

        # INDIVIDUALLY REVERTIBLE: reverting ONE composite commit (capture gamma) does not force
        # reverting its sibling (refresh alpha), though both touched the shared INDEX.md.
        rv = git(vault, "revert", "--no-edit", gamma_sha)
        check("revert of one composite commit succeeds cleanly (no forced co-revert)", rv.returncode == 0, rv.stderr)
        check("revert: tree clean — no INDEX conflict", git(vault, "status", "--porcelain").stdout.strip() == "")
        check("revert: the reverted slug is undone (gamma gone from main)",
              git(vault, "cat-file", "-e", "HEAD:test-topic/knowledge/gamma.md").returncode != 0)
        check("revert: the sibling verb is untouched (alpha still narrowed)",
              "Alpha after the split" in git(vault, "show", "HEAD:test-topic/knowledge/alpha.md").stdout)

        # RESTARTABLE COMPOSITE with a REMOVE verb: merge zeta into alpha (refresh + remove).
        # remove is the verb skip-by-log is REQUIRED for — a blind re-run of `remove <slug>` after
        # it committed dies "entry not found"; this pins that the restart SKIPS it (split never
        # exercises remove).
        rz = run(cfg, vault, sources, ["capture", "zeta", "--trailer", "Heal-mode:auto"],
                 entry("zeta", "Zeta — a sibling that will be absorbed into alpha."))
        check("setup: zeta captured on main", rz.returncode == 0, rz.stderr)
        merge_tr = [("Heal-verdict", "merge"), ("Heal-mode", "ratified"), ("Heal-run", "selftest-2")]
        merge_op = [
            ("refresh", "alpha", entry("alpha", "Alpha, now absorbing zeta's content."), merge_tr),
            ("remove", "zeta", None, merge_tr),
        ]
        git(vault, "worktree", "add", "-q", "-b", "proposal/t2-merge-1", wt, "main")
        mi = apply_sequence(cfg, vault, wt, sources, "main", "proposal/t2-merge-1", merge_op[:1])
        check("merge-op interrupted: only the refresh applied", mi == ["refresh alpha"], mi)
        mr = apply_sequence(cfg, vault, wt, sources, "main", "proposal/t2-merge-1", merge_op)
        check("merge-op restart runs only the remove (refresh skipped)", mr == ["remove zeta"], mr)
        # THE key check: a full re-run skips the committed remove — NOT retried into the engine's
        # "entry not found" (which would raise inside apply_sequence).
        mn = apply_sequence(cfg, vault, wt, sources, "main", "proposal/t2-merge-1", merge_op)
        check("merge-op re-run is a no-op (committed remove is skipped, no 'not found' error)", mn == [], mn)
        cnt = git(vault, "rev-list", "--count", "main..proposal/t2-merge-1").stdout.strip()
        check("merge-op landed exactly 2 commits", cnt == "2", "commits=%s" % cnt)
        check("merge-op: the removed entry's file is gone on the branch",
              git(wt, "cat-file", "-e", "HEAD:test-topic/knowledge/zeta.md").returncode != 0)
        check("merge-op: the removed entry's INDEX line is gone on the branch",
              "knowledge/zeta.md" not in git(wt, "show", "HEAD:test-topic/INDEX.md").stdout)
        msubs = git(vault, "log", "--format=%s", "main..proposal/t2-merge-1").stdout.splitlines()
        check("merge-op commits are engine-shaped (incl. the remove verb)",
              all(re.match(r"^test-topic: (capture|refresh|remove) \S+$", s) for s in msubs)
              and "test-topic: remove zeta" in msubs, msubs)
        git(vault, "worktree", "remove", "--force", wt)
        git(vault, "branch", "-q", "-D", "proposal/t2-merge-1")

        # === AUTO PATH (gate's mechanical branch): commit straight to main, Heal-mode: auto ===
        before = int(git(vault, "rev-list", "--count", "HEAD").stdout)
        ra = run(cfg, vault, sources, ["refresh", "alpha", "--trailer", "Heal-mode:auto",
                                       "--trailer", "Heal-verdict:dead-link"],
                 entry("alpha", "Alpha with a swapped-in live citation — mechanical, claim-preserving."))
        check("auto heal commits straight to main", ra.returncode == 0, ra.stderr)
        check("auto path adds exactly one commit to main",
              int(git(vault, "rev-list", "--count", "HEAD").stdout) == before + 1)
        check("auto commit carries Heal-mode: auto",
              "Heal-mode: auto" in git(vault, "log", "-1", "--format=%B").stdout)

        # === QUARANTINE (T1 / W3): a degraded refresh lands on main with the ⚠ down-rank and
        # Heal-* provenance through the skill's route — and a sub-bar source WITHOUT the marker is
        # refused (never written dirty). The engine's degraded-admit + ⚠ unit is pinned in
        # engine/selftest; this pins it end-to-end through the maintenance refresh+provenance route,
        # which is W3's degraded-quarantine acceptance criterion. The route CHOICE (quarantine ->
        # proposal, Heal-mode: ratified) is skill prose, not engine code, so it is out of this harness.
        subbar = ('---\nname: alpha\ndescription: trigger for alpha\nlast_refreshed: 2026-06-20\n'
                  'sources:\n  - Author, "Decayed", 2026 — https://medium.com/x\n%s---\n\n%s\n')
        dirty = run(cfg, vault, sources, ["refresh", "alpha", "--trailer", "Heal-mode:auto"],
                    subbar % ("", "Alpha with only a sub-bar source and no degraded marker."))
        check("sub-bar refresh WITHOUT a degraded marker is refused (not written dirty)",
              dirty.returncode != 0 and "source authority" in dirty.stderr, dirty.stderr)
        before_q = int(git(vault, "rev-list", "--count", "HEAD").stdout)
        rq = run(cfg, vault, sources,
                 ["refresh", "alpha", "--trailer", "Heal-mode:ratified", "--trailer", "Heal-verdict:degraded"],
                 subbar % ('degraded: "sole source medium.com below the bar; no replacement found"\n',
                           "Alpha, quarantined: its only source decayed below the bar."))
        check("degraded refresh is admitted via the quarantine exemption", rq.returncode == 0, rq.stderr)
        # The ratified lighter-path write (skill routes quarantine -> proposal); the one commit lands
        # on main on the maintainer's yes — NOT an auto write (which the round-1 design removed).
        check("quarantine ratified-refresh adds exactly one commit to main",
              int(git(vault, "rev-list", "--count", "HEAD").stdout) == before_q + 1)
        check("quarantined entry is ⚠-down-ranked in INDEX",
              "- ⚠ [alpha](knowledge/alpha.md)" in git(vault, "show", "HEAD:test-topic/INDEX.md").stdout)
        qbody = git(vault, "log", "-1", "--format=%B").stdout
        check("quarantine commit carries Heal-verdict: degraded + Heal-mode: ratified",
              "Heal-verdict: degraded" in qbody and "Heal-mode: ratified" in qbody, qbody)
    finally:
        shutil.rmtree(root, ignore_errors=True)

    passed = sum(1 for ok in _checks if ok)
    total = len(_checks)
    print("\n%s: %d/%d checks passed" % ("PASS" if passed == total else "FAIL", passed, total))
    return 0 if passed == total else 1


if __name__ == "__main__":
    raise SystemExit(main())

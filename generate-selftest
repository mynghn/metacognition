#!/usr/bin/env python3
"""generate-selftest — derivation + guard tests for the sibling generator (G1 layer).

Encodes the adversarial findings so they cannot regress:
  - CONFIG PARITY (SPEC#INV-1): the derived config for each shipped sibling, given the right
    --index-heading, reproduces config/<stem> BYTE-FOR-BYTE — and is exactly 4 fields, with
    NO `noun` line (the installer computes @NOUN@ from index_heading; storing one diverges).
  - env_prefix = stem initials, with a UNIQUENESS GUARD the installer lacks: a collision is a
    CLEAN error (no traceback), resolvable with --env-prefix. (Near-miss: agent-architectures=AA
    vs agent-runtime=AR.)
  - index_heading has no registry source -> defaults to "Concepts" (SPEC#O-2: stem-only
    yields a valid config), overridable.
  - tier comes from the FAMILY.md section; an off-registry stem with no --tier is a clean error.
  - DESCRIPTION is SEED-AND-FLAG, never fabricated on the auto-invoke path: mechanical opener +
    "<a/an> <stem> <noun>" tail are filled; the no-source "Use when …" triggers are an [AUTHOR]
    stub; scope + neighbour glosses are [DRAFT]; the whole thing is --description-overridable.
  - the tail noun is an authored value (default noun_of(index_heading) is only a GUESS):
    context-engineering ships "principle", not noun_of("Concepts")="concept" — so --noun must
    override it. A generator that hard-derived the noun would mis-write CE's own description.
  - a named neighbour absent from the registry is WARNED, not failed (the seam is a conceptual
    family link the installer never checks; a typo must still surface).
"""
import os
import re
import shutil
import subprocess
import sys
import tempfile

ROOT = os.path.dirname(os.path.abspath(__file__))
GEN = os.path.join(ROOT, "generate")
CONFIG = os.path.join(ROOT, "config")
ENGINE = os.path.join(ROOT, "engine", "kb-engine")
SHIPPED_INDEX = os.path.join(os.path.dirname(ROOT), "metacognition-vault", "context-engineering", "INDEX.md")
CONFIG_KEYS = ("stem", "index_heading", "env_prefix", "tier")
_ok = []


def check(name, cond, detail=""):
    _ok.append(bool(cond))
    print("  %s %s%s" % ("PASS" if cond else "FAIL", name, ("  — " + detail) if detail and not cond else ""))


def run(args):
    """Derivation/preview mode — ALWAYS --dry-run so the G1 checks never write into the real
    repos. The default action is to WRITE, so a check that omitted --dry-run would scaffold
    a sibling into the live tooling repo + vault for real."""
    return subprocess.run([sys.executable, GEN, "--dry-run"] + args, capture_output=True, text=True)


def run_write(args):
    """Real scaffold (writes) — every G2 caller passes sandboxed --config-dir/--wiring-dir/--vault."""
    return subprocess.run([sys.executable, GEN] + args, capture_output=True, text=True)


def cfg_block(stdout):
    """The 4 rendered config lines, in order — the would-be content of config/<stem>."""
    return [ln for ln in stdout.splitlines() if ln.split(" = ", 1)[0] in CONFIG_KEYS]


def desc_line(stdout):
    for ln in stdout.splitlines():
        if ln.startswith("description = "):
            return ln[len("description = "):]
    return ""


def main():
    # ---- config parity vs the three shipped siblings (INV-1) ----
    parity = [("context-engineering", []),
              ("prompt-engineering", ["--index-heading", "Techniques"]),
              ("tool-design", ["--index-heading", "Practices"])]
    for stem, flags in parity:
        r = run([stem] + flags)
        shipped = open(os.path.join(CONFIG, stem), encoding="utf-8").read().splitlines()
        derived = cfg_block(r.stdout)
        check("parity: %s derived == shipped config" % stem,
              r.returncode == 0 and derived == shipped, "%r vs %r / %s" % (derived, shipped, r.stderr))
        check("parity: %s config has no `noun` field" % stem, all("noun" != ln.split(" = ")[0] for ln in derived))

    # ---- env_prefix derivation + the uniqueness guard the installer lacks ----
    r = run(["agent-architectures"])
    check("env_prefix: agent-architectures -> AA", "env_prefix = AA" in r.stdout, r.stdout)
    check("index_heading: stem-only defaults to Concepts", "index_heading = Concepts" in r.stdout)
    check("tier: agent-architectures -> common (from FAMILY section)", "tier = common" in r.stdout)

    sb = tempfile.mkdtemp(prefix="kb-gen-sb-")
    try:
        with open(os.path.join(sb, "alpha-architecture"), "w", encoding="utf-8") as fh:
            fh.write("stem = alpha-architecture\nindex_heading = X\nenv_prefix = AA\ntier = common\n")
        r = run(["agent-architectures", "--config-dir", sb])
        check("env_prefix collision: clean error (no traceback)",
              r.returncode != 0 and "collides with sibling" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        r = run(["agent-architectures", "--config-dir", sb, "--env-prefix", "AX"])
        check("env_prefix collision resolved by --env-prefix", r.returncode == 0 and "env_prefix = AX" in r.stdout, r.stderr)
    finally:
        for f in os.listdir(sb):
            os.remove(os.path.join(sb, f))
        os.rmdir(sb)

    # ---- description: family shape + seed-and-flag, never fabricated ----
    r = run(["agent-architectures"])
    d = desc_line(r.stdout)
    check("desc: verb-triad opener",
          d.startswith("Retrieve, capture, or refresh distilled agent-architectures knowledge —"))
    check("desc: 'Use when' triggers are an [AUTHOR] stub (not fabricated)",
          "Use when [AUTHOR:" in d)
    check("desc: mechanical tail with correct article + noun guess",
          "or looking up or saving an agent-architectures concept" in d)
    check("desc: neighbour parsed from Boundary cell", "(that is agent-runtime)" in d)
    check("desc: scope + neighbour glosses are [DRAFT] seeds", d.count("[DRAFT:") == 2, d)
    check("desc: reports the authoring TODOs", "to author before install" in r.stderr, r.stderr)

    # tail noun is AUTHORED — default is only a guess; --noun yields CE's real "principle"
    r = run(["context-engineering", "--noun", "principle"])
    check("desc: --noun overrides the tail (CE ships 'principle', not noun_of('Concepts'))",
          "or looking up or saving a context-engineering principle" in desc_line(r.stdout))

    # whole-description escape hatch: verbatim, zero TODOs
    r = run(["agent-architectures", "--description", "Custom verbatim."])
    check("desc: --description is verbatim with no TODOs",
          desc_line(r.stdout) == "Custom verbatim." and "need authoring" not in r.stderr)

    # ---- clean errors + neighbour-typo warning ----
    r = run(["Not_A_Stem"])
    check("bad stem: clean error", r.returncode != 0 and "kebab-case" in r.stderr and "Traceback" not in r.stderr)
    r = run(["brand-new-topic"])
    check("off-registry stem w/o --tier: clean error",
          r.returncode != 0 and "not in the registry" in r.stderr and "Traceback" not in r.stderr)
    r = run(["agent-architectures", "--boundary", "control flow vs sequencing (architectures)"])
    check("unknown neighbour: warned, not failed",
          r.returncode == 0 and "not a known FAMILY stem" in r.stderr and "(that is architectures)" in desc_line(r.stdout), r.stderr)

    # ---- regression guards (red-team findings; these rows/paths were never exercised) ----

    # skill-design's Boundary cell names neighbours in arrow-prose, not parens, AND carries an
    # editorial paren aside "(shared seam, single owner)". The parser must surface the THREE real
    # neighbours and NOT fabricate the aside as a phantom sibling.
    d = desc_line(run(["skill-design"]).stdout)
    for n in ("tool-design", "prompt-engineering", "agent-architectures"):
        check("skill-design: real neighbour %s surfaced" % n, "(that is %s)" % n in d, d)
    check("skill-design: editorial paren aside NOT fabricated as a neighbour",
          "shared seam" not in d and "(that is shared" not in d, d)

    # the env_prefix guard must fire on the EXPLICIT --env-prefix branch too (the escape path the
    # auto-derived error recommends), not only on the auto-derived branch.
    sb2 = tempfile.mkdtemp(prefix="kb-gen-sb-")
    try:
        with open(os.path.join(sb2, "other-sibling"), "w", encoding="utf-8") as fh:
            fh.write("stem = other-sibling\nindex_heading = X\nenv_prefix = ZZ\ntier = common\n")
        r = run(["agent-architectures", "--config-dir", sb2, "--env-prefix", "ZZ"])
        check("env_prefix: explicit --env-prefix collision is also a clean error",
              r.returncode != 0 and "collides with sibling" in r.stderr and "Traceback" not in r.stderr, r.stderr)
    finally:
        for f in os.listdir(sb2):
            os.remove(os.path.join(sb2, f))
        os.rmdir(sb2)

    # strict kebab: trailing / double hyphens reach STEM_RE and die kebab-case; a leading hyphen
    # reaches STEM_RE only past argparse's `--` end-of-options separator (a bare `-foo` is an
    # argparse usage error first — also a rejection, just a different layer). All would otherwise
    # reach install's skill name + vault folder malformed.
    for bad in ("foo-", "foo--bar"):
        r = run([bad, "--tier", "common"])
        check("strict stem rejects %r" % bad, r.returncode != 0 and "kebab-case" in r.stderr, r.stderr)
    r = run(["--tier", "common", "--", "-foo"])
    check("strict stem rejects '-foo' (via STEM_RE past `--`)",
          r.returncode != 0 and "kebab-case" in r.stderr, r.stderr)

    # ---- G2: scaffold writes config + wiring + vault skeleton, rendered from templates ----
    sb = tempfile.mkdtemp(prefix="kb-gen-g2-")
    try:
        cdir, wdir, vault = os.path.join(sb, "config"), os.path.join(sb, "wiring"), os.path.join(sb, "vault")
        scaffold = ["agent-architectures", "--config-dir", cdir, "--wiring-dir", wdir, "--vault", vault, "--no-install"]
        r = run_write(scaffold)
        topic = os.path.join(vault, "agent-architectures")
        cfg_f, wir_f = os.path.join(cdir, "agent-architectures"), os.path.join(wdir, "agent-architectures")
        idx_f, kdir = os.path.join(topic, "INDEX.md"), os.path.join(topic, "knowledge")
        check("G2: scaffold writes config + wiring + INDEX + knowledge/",
              r.returncode == 0 and all(os.path.exists(p) for p in (cfg_f, wir_f, idx_f, kdir)), r.stderr)
        check("G2: knowledge/ is empty (no entries)", os.path.isdir(kdir) and os.listdir(kdir) == [])
        idx = open(idx_f, encoding="utf-8").read()
        check("G2: INDEX has the engine's required '## Concepts' + comment",
              "\n## Concepts\n" in idx and "<!-- one line per concept; appended by capture/refresh via the shared engine -->" in idx)
        check("G2: INDEX records seeds (## Seeds + the topic primary, before ## Concepts)",
              "## Seeds" in idx and "Anthropic, Multi-agent research system" in idx
              and idx.index("## Seeds") < idx.index("## Concepts"))
        check("G2: INDEX renders from templates/index-skeleton.md (boilerplate single-sourced there)",
              "consume during the content build" in idx and os.path.isfile(os.path.join(ROOT, "templates", "index-skeleton.md")))

        # header byte-parity vs the shipped vault INDEX — the ONLY diff is the ## Seeds insert (O-5)
        if os.path.isfile(SHIPPED_INDEX):
            run_write(["context-engineering", "--config-dir", os.path.join(sb, "c2"),
                       "--wiring-dir", os.path.join(sb, "w2"), "--vault", os.path.join(sb, "v2"), "--no-install"])
            gen_ce = open(os.path.join(sb, "v2", "context-engineering", "INDEX.md"), encoding="utf-8").read()
            shipped_full = open(SHIPPED_INDEX, encoding="utf-8").read()
            header = "\n".join(shipped_full.split("\n")[:7])  # H1 .. "Each line:"
            check("G2: generated INDEX header byte-identical to shipped", gen_ce.startswith(header), header)
            # strong O-3/INV-1 guard: generated INDEX minus the ## Seeds insert == shipped pre-entry header
            mfirst = re.search(r"(?m)^- \[", shipped_full)
            shipped_pre = (shipped_full[:mfirst.start()] if mfirst else shipped_full).rstrip("\n")
            gen_no_seeds = re.sub(r"## Seeds\n.*?\n\n(?=## )", "", gen_ce, flags=re.S).rstrip("\n")
            check("G2: generated INDEX == shipped header with ONLY the ## Seeds insert added",
                  gen_no_seeds == shipped_pre, "tail gen=%r vs shipped=%r" % (gen_no_seeds[-60:], shipped_pre[-60:]))
        else:
            print("  SKIP G2 header parity — shipped vault INDEX not at %s" % SHIPPED_INDEX)

        # overwrite guard
        r = run_write(scaffold)
        check("G2: refuse overwrite of an existing sibling (clean error)",
              r.returncode != 0 and "refusing to overwrite" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        r = run_write(scaffold + ["--force"])
        check("G2: --force overwrites", r.returncode == 0, r.stderr)

        # born-running: the shared engine captures into the generated skeleton, ## Seeds preserved
        subprocess.run(["git", "-C", vault, "init", "-q"], check=True)
        subprocess.run(["git", "-C", vault, "config", "user.email", "t@t"], check=True)
        subprocess.run(["git", "-C", vault, "config", "user.name", "t"], check=True)
        entry = ("---\nname: probe-entry\ndescription: a probe trigger\nlast_refreshed: 2026-01-01\n"
                 "sources:\n  - http://example.com\n---\n\nbody\n")
        e = subprocess.run([sys.executable, ENGINE, "--config", cfg_f, "--vault", vault, "capture", "probe-entry"],
                           input=entry, capture_output=True, text=True)
        check("G2: engine captures into the generated skeleton (born-running)",
              e.returncode == 0 and os.path.isfile(os.path.join(kdir, "probe-entry.md")), (e.stdout + e.stderr).strip())
        idx2 = open(idx_f, encoding="utf-8").read()
        check("G2: capture upserts under ## Concepts AND preserves ## Seeds",
              "- [probe-entry](knowledge/probe-entry.md) — a probe trigger" in idx2 and "## Seeds" in idx2, idx2)

        # --force on a content-bearing INDEX warns about de-indexing (not silent)
        r = run_write(scaffold + ["--force"])
        check("G2: --force on an INDEX with entries warns (de-indexing not silent)",
              r.returncode == 0 and "DE-INDEXING" in r.stderr and "probe-entry" in r.stderr, r.stderr)

        # reserved + charset guards on index_heading (the single rendered source value)
        r = run(["agent-architectures", "--index-heading", "Seeds"])
        check("G2: --index-heading Seeds rejected (reserved scaffold heading)",
              r.returncode != 0 and "reserved" in r.stderr and "Traceback" not in r.stderr, r.stderr)
        r = run(["agent-architectures", "--index-heading", "Foo *bar*"])
        check("G2: markdown-active index_heading rejected",
              r.returncode != 0 and "markdown-active" in r.stderr and "Traceback" not in r.stderr, r.stderr)

        # atomic write: --vault is a file -> clean error, no half-scaffold (no config written)
        vf = os.path.join(sb, "vault-is-file")
        open(vf, "w").write("x")
        cf = os.path.join(sb, "cf")
        r = run_write(["evaluation-observability", "--config-dir", cf,
                       "--wiring-dir", os.path.join(sb, "wf"), "--vault", vf, "--no-install"])
        check("G2: --vault is a file -> clean error, no half-scaffold",
              r.returncode != 0 and "not a directory" in r.stderr and "Traceback" not in r.stderr
              and not os.path.exists(os.path.join(cf, "evaluation-observability")), r.stderr)
    finally:
        shutil.rmtree(sb, ignore_errors=True)

    # ---- G3: generate invokes the installer -> both adapters + tier-gated wiring ----
    # The installer reads the tooling repo's own config/ + wiring/ (no path overrides), so the
    # temp siblings live there (removed in finally); adapters / AGENTS.md / vault go to a sandbox.
    sb3 = tempfile.mkdtemp(prefix="kb-gen-g3-")
    rwir = os.path.join(ROOT, "wiring")
    temps = [os.path.join(CONFIG, "selftest-g3"), os.path.join(rwir, "selftest-g3"),
             os.path.join(CONFIG, "selftest-g3e"), os.path.join(rwir, "selftest-g3e"),
             os.path.join(rwir, "selftest-g3e.agents.md")]
    try:
        env = dict(os.environ, XDG_CONFIG_HOME=os.path.join(sb3, "xdg"))
        for k in [k for k in list(env) if k == "KB_VAULT" or k.endswith("_KB_VAULT")]:
            env.pop(k, None)
        dest, vault = os.path.join(sb3, "dest"), os.path.join(sb3, "vault")
        common = ["--config-dir", CONFIG, "--wiring-dir", rwir, "--vault", vault, "--dest", dest]

        def gen(args):
            return subprocess.run([sys.executable, GEN] + args, capture_output=True, text=True, env=env)

        # situational sibling -> description-only; both adapters byte-identical; NO AGENTS.md block
        r = gen(["selftest-g3", "--tier", "situational", "--env-prefix", "SG3",
                 "--scope", "a probe scope", "--description", "A probe description for the g3 selftest."] + common)
        name = "selftest-g3-knowledge-base"
        c = os.path.join(dest, ".claude", "skills", name, "SKILL.md")
        x = os.path.join(dest, ".codex", "skills", name, "SKILL.md")
        check("G3: one run emits both adapters", r.returncode == 0 and os.path.isfile(c) and os.path.isfile(x), (r.stdout + r.stderr))
        check("G3: Claude adapter == Codex adapter (byte-identical)",
              os.path.isfile(c) and os.path.isfile(x) and open(c, encoding="utf-8").read() == open(x, encoding="utf-8").read())
        check("G3: adapter carries the generated description",
              os.path.isfile(c) and "A probe description for the g3 selftest." in open(c, encoding="utf-8").read())
        check("G3: situational tier -> no AGENTS.md block", not os.path.isfile(os.path.join(dest, "AGENTS.md")))
        # born-running: the engine resolves the installer-recorded vault (no --vault / env)
        e = subprocess.run([sys.executable, ENGINE, "--config", os.path.join(CONFIG, "selftest-g3"), "locate"],
                           capture_output=True, text=True, env=env)
        check("G3: engine operates on the new sibling via the recorded vault",
              e.returncode == 0 and os.path.abspath(vault) in e.stdout, (e.stdout + e.stderr))

        # everyday sibling -> the generated draft .agents.md drives an AGENTS.md trigger block
        r = gen(["selftest-g3e", "--tier", "everyday", "--env-prefix", "SE3",
                 "--scope", "a probe", "--description", "A probe everyday description."] + common)
        ag = os.path.join(dest, "AGENTS.md")
        check("G3: everyday tier -> AGENTS.md trigger block emitted",
              r.returncode == 0 and os.path.isfile(ag) and "<selftest_g3e>" in open(ag, encoding="utf-8").read(), (r.stdout + r.stderr))
        check("G3: everyday sibling generated its draft .agents.md block",
              os.path.isfile(os.path.join(rwir, "selftest-g3e.agents.md")))

        # --no-install stops at the scaffold (installer never runs)
        r = gen(["selftest-g3", "--tier", "situational", "--env-prefix", "SG3", "--scope", "x",
                 "--description", "y", "--force", "--no-install"] + common)
        check("G3: --no-install stops at scaffold (installer not run)",
              r.returncode == 0 and "install:" not in r.stdout, (r.stdout + r.stderr))

        # a custom --config-dir with install requested fails fast (installer reads the repo's config/)
        r = gen(["selftest-g3", "--tier", "situational", "--env-prefix", "SG3", "--scope", "x",
                 "--description", "y", "--config-dir", os.path.join(sb3, "custom")])
        check("G3: custom --config-dir + install -> clean fail-fast",
              r.returncode != 0 and "installer reads" in r.stderr and "Traceback" not in r.stderr, r.stderr)

        # bad --dest (under a file) -> clean generate error, no installer traceback leak
        badparent = os.path.join(sb3, "afile")
        open(badparent, "w").write("x")
        r = gen(["selftest-g3", "--tier", "situational", "--env-prefix", "SG3", "--scope", "x",
                 "--description", "y", "--force", "--dest", os.path.join(badparent, "sub"),
                 "--config-dir", CONFIG, "--wiring-dir", rwir, "--vault", vault])
        check("G3: bad --dest -> clean error (no installer traceback)",
              r.returncode != 0 and "--dest" in r.stderr and "Traceback" not in r.stderr, r.stderr)

        # tier-gated overwrite clash message: everyday names the .agents.md draft; situational does not
        noinst = ["--no-install", "--config-dir", CONFIG, "--wiring-dir", rwir, "--vault", vault]
        r = gen(["selftest-g3e", "--tier", "everyday", "--env-prefix", "SE3", "--scope", "a", "--description", "d"] + noinst)
        check("G3: everyday re-scaffold clash names the .agents.md draft",
              r.returncode != 0 and "selftest-g3e.agents.md" in r.stderr, r.stderr)
        r = gen(["selftest-g3", "--tier", "situational", "--env-prefix", "SG3", "--scope", "a", "--description", "d"] + noinst)
        check("G3: situational re-scaffold clash does NOT name a .agents.md",
              r.returncode != 0 and "agents.md" not in r.stderr, r.stderr)

        # single-char auto-derived env_prefix (single-token stem) warns (collision-prone)
        r = run(["redteamsolo", "--tier", "situational"])
        check("G3: single-char auto env_prefix warns", "single character" in r.stderr, r.stderr)
    finally:
        for p in temps:
            if os.path.exists(p):
                os.remove(p)
        shutil.rmtree(sb3, ignore_errors=True)

    passed, total = sum(_ok), len(_ok)
    print("\n%s: %d/%d checks passed" % ("PASS" if passed == total else "FAIL", passed, total))
    return 0 if passed == total else 1


if __name__ == "__main__":
    raise SystemExit(main())
